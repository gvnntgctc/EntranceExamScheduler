<!DOCTYPE html>
<html>
<head>
  <title>Admin - Students</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="admin-page-bg">
  <style>
    .search-bar { 
      display: flex; 
      gap: 12px; 
      margin-bottom: 20px; 
      align-items: center; 
      /* keep items on the same row until small screens */
      flex-wrap: nowrap;
      background: rgba(255, 255, 255, 0.76);
      border: 1px solid rgba(220, 227, 235, 0.65);
      border-radius: 12px;
      padding: 10px 12px;
      box-shadow: 0 8px 18px rgba(14, 30, 37, 0.08);
    }
    .search-input-wrapper {
      position: relative;
      /* slightly increase base width so dropdown has more room beside it */
      flex: 1 1 320px;
      min-width: 240px;
      max-width: 950px;
    }
    .search-input-wrapper .search-input {
      min-width: 0; /* allow the input to shrink within flex container */
    }
    .search-input-wrapper i {
      position: absolute;
      top: 50%;
      left: 12px;
      transform: translateY(-50%);
      color: #7f8fa4;
      font-size: 14px;
      pointer-events: none;
    }
    .search-bar input { 
      width: 100%; 
      padding: 12px 14px 12px 38px; 
      border: 1px solid #c8d5e0; 
      border-radius: 8px; 
      font-size: 14px; 
      box-shadow: inset 0 1px 4px rgba(15, 23, 42, 0.06);
      transition: all 0.2s ease;
    }
    .search-bar input:focus {
      outline: none;
      border-color: #11998e;
      box-shadow: 0 0 0 3px rgba(17, 153, 142, 0.2);
    }
    .search-bar select { 
      padding: 10px 12px; 
      border: 1px solid #c3cdd9; 
      border-radius: 8px; 
      font-size: 14px; 
      background: rgba(255, 255, 255, 0.80);
      color: #2f3b4a;
      transition: border-color 0.2s ease, box-shadow 0.2s ease;
      flex: 0 0 auto;
      margin-left: 8px;
      width: auto; /* fit content */
      min-width: 110px; /* sensible minimum */
      max-width: 180px; /* prevent overly long dropdown */
      box-sizing: border-box;
      white-space: nowrap;
      text-overflow: ellipsis;
      overflow: hidden;
    }
    .search-bar select:focus {
      outline: none;
      border-color: #11998e;
      box-shadow: 0 0 0 3px rgba(17, 153, 142, 0.2);
    }
    .search-bar button, .search-bar a { 
      padding: 10px 14px; 
      white-space: nowrap;
      min-width: 90px;
    }
    .search-bar button.btn-secondary {
      background: #f1f5f9;
      border: 1px solid #c3cdd9;
      color: #334155;
      border-radius: 8px;
      transition: all 0.2s ease;
    }
    .search-bar button.btn-secondary:hover {
      background: #e2e8f0;
      transform: translateY(-1px);
    }
    .students-table {
      width: 100%;
      border-collapse: collapse;
    }
    .students-table thead {
      background: #f5f6fa;
      border-bottom: 2px solid #e0e0e0;
    }
    .students-table th {
      padding: 16px 18px;
      text-align: left;
      font-weight: 600;
      color: #555;
      font-size: 15px;
    }
    .students-table td {
      padding: 18px;
      border-bottom: 1px solid #f0f0f0;
      font-size: 15px;
    }
    .students-table tbody tr:hover {
      background: #f9f9f9;
    }
    .student-name {
      font-weight: 600;
      color: #2c3e50;
      font-size: 16px;
    }
    .student-email {
      color: #666;
      font-size: 15px;
    }
    .student-date {
      color: #888;
      font-size: 14px;
    }
    .actions-column {
      text-align: center;
      white-space: nowrap;
    }
    .status-badge {
      display: inline-block;
      padding: 4px 8px;
      border-radius: 12px;
      font-size: 12px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    .status-pending {
      background: #fff3cd;
      color: #856404;
      border: 1px solid #ffeaa7;
    }
    .status-passed {
      background: #d4edda;
      color: #155724;
      border: 1px solid #c3e6cb;
    }
    .filter-indicator {
      font-size: 12px;
      color: #666;
      font-weight: normal;
      margin-left: 8px;
    }
    .edit-btn {
      background: #4CAF50;
      color: white;
    }
    .edit-btn:hover {
      background: linear-gradient(135deg, #0e7a70 0%, #2dd66f 100%);
      transform: translateY(-2px);
    }
    .delete-btn {
      background: #f44336;
      color: white;
    }
    .delete-btn:hover {
      background: #da190b;
      transform: translateY(-2px);
    }
    .modal {
      display: none;
      position: fixed;
      z-index: 1000;
      inset: 0;
      background-color: rgba(15, 23, 42, 0.55);
      animation: fadeIn 0.3s ease;
      backdrop-filter: blur(4px);
      padding: 16px;
    }
    .modal.show {
      display: flex;
      align-items: center;
      justify-content: center;
    }
    @keyframes fadeIn {
      from { opacity: 0; }
      to { opacity: 1; }
    }
    .modal-content {
      background-color: rgba(255, 255, 255, 0.96);
      color: #0f172a;
      padding: 0;
      border-radius: 18px;
      box-shadow: 0 24px 60px rgba(15, 23, 42, 0.18);
      width: min(92vw, 520px);
      max-height: 90vh;
      overflow: hidden;
      border: 1px solid rgba(148, 163, 184, 0.18);
      text-align: left;
    }
    .modal-header {
      background: linear-gradient(135deg, #1B5E20 0%, #2E7D32 100%);
      color: #ffffff;
      padding: 22px 24px;
      font-size: 1.1rem;
      font-weight: 700;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 12px;
      text-align: center;
    }
    .modal-header i {
      color: #f8fafc;
      font-size: 1.25rem;
    }
    .modal-body {
      color: #334155;
      padding: 24px;
      font-size: 0.96rem;
      line-height: 1.75;
      overflow-y: auto;
      max-height: calc(90vh - 160px);
    }
    .modal-body p {
      margin: 0 0 18px;
      color: inherit;
    }
    .modal-summary-card {
      background: rgba(56, 189, 248, 0.08);
      border-left: 4px solid #2563eb;
      padding: 18px;
      border-radius: 14px;
      margin-bottom: 18px;
    }
    .modal-summary-card .summary-title {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 12px;
      font-size: 0.82rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #0f172a;
    }
    .modal-summary-card ul {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      gap: 10px;
    }
    .modal-summary-card li {
      background: #ffffff;
      color: #334155;
      border: 1px solid rgba(203, 213, 225, 0.75);
      border-radius: 10px;
      padding: 12px 14px;
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 0.93rem;
    }
    .modal-summary-card li i {
      color: #2563eb;
      min-width: 16px;
      text-align: center;
    }
    .modal-actions {
      display: flex;
      gap: 12px;
      justify-content: flex-end;
      flex-wrap: wrap;
      padding: 0 24px 20px;
    }
    .modal-actions button {
      min-width: 120px;
      padding: 12px 18px;
      border: 1px solid transparent;
      border-radius: 10px;
      font-weight: 700;
      cursor: pointer;
      transition: transform 0.2s ease, background-color 0.2s ease, border-color 0.2s ease;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
    }
    .modal-actions button:hover:not(:disabled) {
      transform: translateY(-1px);
    }
    .modal-actions button.loading {
      opacity: 0.7;
      cursor: not-allowed;
    }
    .modal-actions button.loading .fa-spinner {
      animation: spin 1s linear infinite;
    }
    @keyframes spin {
      from { transform: rotate(0deg); }
      to { transform: rotate(360deg); }
    }
    .confirm-delete {
      color: #ffffff;
    }
    .confirm-delete:hover {
      filter: brightness(0.96);
    }
    .cancel-delete {
      background: #f8fafc;
      color: #111827;
      border-color: #cbd5e1;
    }
    .cancel-delete:hover {
      background: #e2e8f0;
    }
    @media (max-width: 520px) {
      .modal {
        padding: 10px;
      }
      .modal-content {
        width: 100%;
        border-radius: 16px;
      }
      .modal-header {
        padding: 18px 18px;
        font-size: 1rem;
      }
      .modal-body {
        padding: 18px;
      }
      .modal-actions {
        justify-content: stretch;
      }
      .modal-actions button {
        width: 100%;
      }
    }
    body.dark .modal-content,
    .dark-mode .modal-content {
      background-color: rgba(15, 23, 42, 0.96);
      color: #f8fafc;
      border-color: rgba(148, 163, 184, 0.24);
    }
    body.dark .modal-header,
    .dark-mode .modal-header {
      background: #0f172a;
    }
    body.dark .modal-body,
    .dark-mode .modal-body {
      color: #e2e8f0;
    }
    body.dark .modal-summary-card,
    .dark-mode .modal-summary-card {
      background: rgba(96, 165, 250, 0.1);
    }
    body.dark .modal-summary-card li,
    .dark-mode .modal-summary-card li {
      background: rgba(15, 23, 42, 0.9);
      color: #e2e8f0;
      border-color: rgba(71, 85, 105, 0.35);
    }
    body.dark .cancel-delete,
    .dark-mode .cancel-delete {
      background: #1f2937;
      color: #f8fafc;
      border-color: #374151;
    }
    body.dark .cancel-delete:hover,
    .dark-mode .cancel-delete:hover {
      background: #111827;
    }
    body.dark .modal {
      background-color: rgba(0, 0, 0, 0.65);
    }
    
    /* Bulk Loading Overlay Styles */
    .bulk-loading-overlay {
      display: none;
      position: fixed;
      z-index: 9999;
      left: 0;
      top: 0;
      width: 100%;
      height: 100%;
      background-color: rgba(0, 0, 0, 0.7);
      animation: fadeIn 0.3s ease;
    }
    .bulk-loading-overlay.show {
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .bulk-loading-content {
      background: rgba(255, 255, 255, 0.82);
      border-radius: 16px;
      padding: 40px;
      text-align: center;
      box-shadow: 0 20px 60px rgba(0, 0, 0, 0.26);
      border: 1px solid rgba(255, 255, 255, 0.65);
      max-width: 400px;
      width: 90%;
    }
    .bulk-loading-spinner {
      display: block;
      margin: 0 auto 18px;
      width: 64px;
      height: 64px;
    }
    .bulk-loading-spinner .lds-ring {
      display: inline-block;
      position: relative;
      width: 64px;
      height: 64px;
    }
    .bulk-loading-spinner .lds-ring div {
      box-sizing: border-box;
      display: block;
      position: absolute;
      width: 52px;
      height: 52px;
      margin: 6px;
      border: 6px solid #11998e;
      border-radius: 50%;
      animation: lds-ring 1.2s cubic-bezier(0.5, 0, 0.5, 1) infinite;
      border-color: #11998e transparent transparent transparent;
    }
    .bulk-loading-spinner .lds-ring div:nth-child(2) {
      animation-delay: -0.45s;
      border-color: transparent #11998e transparent transparent;
    }
    .bulk-loading-spinner .lds-ring div:nth-child(3) {
      animation-delay: -0.3s;
      border-color: transparent transparent #11998e transparent;
    }
    .bulk-loading-spinner .lds-ring div:nth-child(4) {
      animation-delay: -0.15s;
      border-color: transparent transparent transparent #11998e;
    }
    .bulk-loading-text {
      padding: 0;
    }
    .bulk-loading-text.simple-processing p {
      color: #11998e;
      margin: 0;
      font-size: 20px;
      font-weight: 700;
      letter-spacing: 0.02em;
      line-height: 1.4;
    }
    
    /* Loading Spinner Animation */
    @keyframes lds-ring {
      0% {
        transform: rotate(0deg);
      }
      100% {
        transform: rotate(360deg);
      }
    }
  </style>

  <!-- Responsive Styles for Table -->
  <style>
    @media (max-width: 900px) {
      .sidebar {
        transform: translateX(-100%) !important;
      }

      .sidebar.open {
        transform: translateX(0) !important;
      }

      .hamburger {
        display: flex !important;
      }

      .main-content {
        margin-left: 0 !important;
        width: 100% !important;
      }
    }

    @media (max-width: 768px) {
      .students-table {
        display: block;
        width: 100%;
        min-width: 0;
        table-layout: auto;
        white-space: normal;
      }

      .students-table thead {
        display: none;
      }

      .students-table tbody {
        display: block;
      }

      .students-table tr {
        display: grid;
        grid-template-columns: auto 1fr auto;
        grid-template-areas:
          "checkbox index actions"
          "fullname fullname fullname"
          "email email email"
          "status registered registered";
        gap: 8px 12px;
        margin-bottom: 12px;
        border: 1px solid #e5e7eb;
        border-radius: 18px;
        padding: 12px 14px;
        background: #ffffff;
        box-shadow: 0 10px 24px rgba(15, 23, 42, 0.06);
      }

      .students-table td {
        display: block;
        width: 100%;
        padding: 4px 0;
        border: none;
        box-sizing: border-box;
        white-space: normal;
        overflow-wrap: anywhere;
        word-break: break-word;
        line-height: 1.35;
      }

      .students-table td:first-child {
        grid-area: checkbox;
        padding-top: 6px;
        padding-bottom: 6px;
      }

      .students-table td:nth-child(2) {
        grid-area: index;
        padding-top: 6px;
        padding-bottom: 6px;
      }

      .students-table td:nth-child(3) {
        grid-area: fullname;
        padding-top: 6px;
        padding-bottom: 6px;
      }

      .students-table td:nth-child(4) {
        grid-area: email;
        padding-top: 6px;
        padding-bottom: 6px;
      }

      .students-table td:nth-child(5) {
        grid-area: status;
        padding-top: 6px;
        padding-bottom: 6px;
      }

      .students-table td:nth-child(6) {
        grid-area: registered;
        padding-top: 6px;
        padding-bottom: 6px;
      }

      .students-table td:last-child {
        grid-area: actions;
        justify-self: end;
        padding-top: 6px;
        padding-bottom: 6px;
      }

      .students-table td:first-child:before,
      .students-table td:nth-child(2):before,
      .students-table td:last-child:before {
        display: none;
      }

      .students-table td:before {
        content: attr(data-label);
        display: block;
        margin-bottom: 3px;
        font-size: 11px;
        font-weight: 700;
        color: #526075;
        letter-spacing: 0.02em;
      }

      .student-name {
        font-size: 15px;
        line-height: 1.35;
      }

      .student-email,
      .student-date {
        font-size: 13px;
        line-height: 1.35;
        color: #5d6c7e;
      }

      .status-badge {
        font-size: 12px;
        padding: 4px 10px;
      }

      .action-btn {
        display: inline-flex;
        width: auto;
        max-width: 140px;
        padding: 9px 12px;
        font-size: 13px;
        line-height: 1.2;
        justify-content: center;
        border-radius: 10px;
      }

      .actions-column {
        text-align: right;
      }

      .bulk-actions-bar {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        justify-content: flex-end;
      }

      .bulk-actions-bar > div {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        justify-content: flex-end;
        width: auto;
      }

      .bulk-actions-bar > div > button {
        width: auto;
        min-width: 120px;
        padding: 10px 12px;
        font-size: 13px;
      }

      .students-table td:nth-child(2) strong {
        font-size: 13px;
      }
    }

    @media (max-width: 600px) {
      .sidebar {
        transform: translateX(-100%) !important;
      }

      .sidebar.open {
        transform: translateX(0) !important;
      }

      .hamburger {
        display: flex !important;
      }

      .main-content {
        margin-left: 0 !important;
        width: 100% !important;
        padding: 18px 12px 26px !important;
      }

      .container {
        padding: 0 !important;
        max-width: 100% !important;
      }

      .search-bar {
        flex-direction: column;
        gap: 10px;
        align-items: stretch;
        width: 100%;
        padding: 10px 10px;
      }

      .search-input-wrapper {
        flex: 1 1 auto !important;
        width: 100% !important;
        max-width: 100% !important;
        min-width: 0 !important;
      }

      .search-bar select {
        width: 100% !important;
        min-width: 0 !important;
        margin-left: 0 !important;
      }

      .search-bar button,
      .search-bar a {
        width: 100%;
        justify-content: center;
      }

      .students-table tr {
        grid-template-columns: auto 1fr;
        grid-template-areas:
          "checkbox index"
          "fullname fullname"
          "email email"
          "status registered"
          "actions actions";
      }

      .students-table td:last-child {
        justify-self: start;
      }

      .students-table td {
        padding: 5px 0;
        line-height: 1.35;
      }

      .students-table td:before {
        margin-bottom: 2px;
        font-size: 11px;
      }

      .action-btn {
        max-width: 120px;
        padding: 9px 12px;
        line-height: 1.2;
      }

      .actions-column {
        text-align: left;
      }

      .bulk-actions-bar {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        justify-content: flex-end;
      }

      .bulk-actions-bar > div {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        justify-content: flex-end;
        width: auto;
      }

      .bulk-actions-bar > div > button {
        width: auto;
        min-width: 110px;
        padding: 10px 12px;
        font-size: 13px;
      }
    }

    @media (max-width: 480px) {
      .section-card {
        padding: 15px;
      }

      .section-header h2 {
        font-size: 18px;
      }

      .student-count-badge {
        font-size: 12px;
      }

      .search-bar {
        flex-direction: column;
        gap: 10px;
        flex-wrap: wrap;
      }

      .search-bar input {
        width: 100%;
      }
      .search-bar select {
        width: 100%;
        min-width: 0;
        margin-left: 0;
      }
    }
  </style>

  <%- include('partials/sidebar'); %>
  <div class="sidebar-overlay" id="sidebarOverlay"></div>
  <button class="hamburger" id="hamburger"><i class="fas fa-bars"></i></button>

  <!-- Main Content -->
  <div class="main-content">
    <div class="page-logo">
      <img src="/images/logo.png" alt="PTC Logo" />
    </div>
    <div class="container">
      <h1><i class="fas fa-users"></i> Registered Applicants</h1>

      <% if (error && error.length > 0) { %>
        <div class="message error">
          <i class="fas fa-exclamation-triangle"></i> <%= error %>
        </div>
      <% } %>

      <% if (success && success.length > 0) { %>
        <div class="message success">
          <i class="fas fa-check-circle"></i> <%= success %>
        </div>
      <% } %>

      <div class="section-card">
        <div class="section-header">
          <h2><i class="fas fa-list"></i> All Registered Applicants</h2>
          <div class="student-count-badge">
            <%= students.length %> Students
            <% if (typeof status !== 'undefined' && status !== 'all') { %>
              <span class="filter-indicator">(Filtered: <%= status %>)</span>
            <% } %>
          </div>
        </div>

        <% if (students.length > 0) { %>
          <div class="search-bar">
            <div class="search-input-wrapper">
              <i class="fas fa-search search-icon"></i>
              <input 
                id="studentSearch" 
                class="search-input"
                type="search" 
                placeholder="Search by name or email..." 
                aria-label="Search students"
                value="<%= typeof search !== 'undefined' ? search : '' %>"
                autocomplete="off"
              />
            </div>
            <select id="statusFilter" aria-label="Filter by status">
              <option value="all" <%= typeof status === 'undefined' || status === 'all' ? 'selected' : '' %>>All Status</option>
              <option value="pending" <%= typeof status !== 'undefined' && status === 'pending' ? 'selected' : '' %>>Pending</option>
              <option value="passed" <%= typeof status !== 'undefined' && status === 'passed' ? 'selected' : '' %>>Passed</option>
              <option value="failed" <%= typeof status !== 'undefined' && status === 'failed' ? 'selected' : '' %>>Failed</option>
            </select>
          </div>

          <!-- Bulk Actions Bar -->
          <div class="bulk-actions-bar" style="display: flex; gap: 10px; align-items: center; margin-top: 15px; padding: 15px; background: #f8f9fa; border-radius: 8px; border: 1px solid #e0e0e0;">
            <div style="flex: 1;"></div>
            <div style="display: flex; gap: 10px;">
              <button type="button" id="bulkPassBtn" class="action-btn edit-btn" style="background: #28a745; border-color: #28a745;" disabled>
                <i class="fas fa-check"></i> Pass Selected
              </button>
              <button type="button" id="bulkFailBtn" class="action-btn delete-btn" style="background: #dc3545; border-color: #dc3545;" disabled>
                <i class="fas fa-times"></i> Fail Selected
              </button>
              <button type="button" id="bulkDeleteBtn" class="action-btn delete-btn" style="background: #c82333; border-color: #bd2130;" disabled>
                <i class="fas fa-trash"></i> Delete Selected
              </button>
            </div>
          </div>
        <% } %>

        <% if (students.length === 0) { %>
          <div class="no-data">
            <i class="fas fa-users"></i>
            <p>No students registered yet.</p>
          </div>
        <% } else { %>

          <table class="students-table" id="studentsGrid">
            <thead>
              <tr>
                <th style="width: 50px;"><input type="checkbox" id="headerCheckbox" style="width: 18px; height: 18px;"></th>
                <th>#</th>
                <th>Full Name</th>
                <th>Email</th>
                <th>Status</th>
                <th>Registered</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% students.forEach((student, index) => { %>
                <tr>
                  <td><input type="checkbox" class="student-checkbox" value="<%= student._id.toString() %>" style="width: 18px; height: 18px;"></td>
                  <td data-label="#"><strong><%= index + 1 %></strong></td>
                  <td data-label="Full Name" class="student-name"><%= student.fullName %></td>
                  <td data-label="Email" class="student-email"><%= student.email %></td>
                  <td data-label="Status">
                    <span class="status-badge status-<%= student.status || 'pending' %>">
                      <%= (student.status || 'pending').charAt(0).toUpperCase() + (student.status || 'pending').slice(1) %>
                    </span>
                  </td>
                  <td data-label="Registered" class="student-date">
                    <% if (student.createdAt) { %>
                      <%= student.createdAt.toDateString() %>
                    <% } %>
                  </td>
                  <td data-label="Actions" class="actions-column">
                    <button type="button" class="action-btn edit-btn" onclick="viewStudent('<%= student._id.toString() %>')">
                      <i class="fas fa-eye"></i> View
                    </button>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>

      <!-- Bulk Status / Delete Confirmation Modal -->
      <!-- Bulk Status / Delete Confirmation Modal -->
    </div>
  </div>
</div>

  <!-- STUDENT DETAILS MODAL -->
  <div id="studentModalBg" class="student-modal-bg" onclick="closeStudentModal()" style="display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; width: 100%; height: 100%; background: rgba(0, 0, 0, 0.7); z-index: 9998; justify-content: center; align-items: center;"></div>
  <div id="studentModal" class="student-modal" style="display: none; width: 90%; max-width: 650px; max-height: 90vh; background: rgba(255, 255, 255, 0.88); border-radius: 16px; box-shadow: 0 25px 50px rgba(0, 0, 0, 0.25), 0 0 0 1px rgba(255, 255, 255, 0.35); overflow: hidden; flex-direction: column; z-index: 9999;">
    <div class="student-modal-content" style="display: flex; flex-direction: column; height: 100%; background: rgba(255, 255, 255, 0.90);">
      <div class="student-modal-header" style="background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%); padding: 30px; color: white; display: flex; justify-content: space-between; align-items: center; box-shadow: 0 2px 8px rgba(17, 153, 142, 0.2);">
        <div style="display: flex; align-items: center; gap: 15px;">
          <div style="font-size: 32px; background: rgba(255, 255, 255, 0.2); width: 50px; height: 50px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
            <i class="fas fa-user-circle"></i>
          </div>
          <div>
            <div style="font-size: 12px; opacity: 0.9; text-transform: uppercase; letter-spacing: 1px;">Student Profile</div>
            <h2 id="studentModalName" style="margin: 0; font-size: 24px; font-weight: 700; color: white;"></h2>
          </div>
        </div>
        <button class="student-modal-close" onclick="closeStudentModal()" style="background: rgba(255, 255, 255, 0.25); border: none; color: white; font-size: 24px; cursor: pointer; padding: 10px 14px; border-radius: 8px; transition: all 0.3s ease; display: flex; align-items: center; justify-content: center;">
          <i class="fas fa-times"></i>
        </button>
      </div>
      
      <div class="student-modal-body" style="padding: 30px; overflow-y: auto; flex: 1; background: #f8f9fa; max-height: calc(90vh - 150px);">
        <!-- Loading Spinner -->
        <div id="studentModalLoader" style="display: none; text-align: center; padding: 60px 30px;">
          <div style="display: inline-block; position: relative; width: 60px; height: 60px;">
            <div style="box-sizing: border-box; display: block; position: absolute; width: 48px; height: 48px; margin: 6px; border: 5px solid #11998e; border-radius: 50%; animation: lds-ring 1.2s cubic-bezier(0.5, 0, 0.5, 1) infinite; border-color: #11998e transparent transparent transparent;"></div>
            <div style="box-sizing: border-box; display: block; position: absolute; width: 48px; height: 48px; margin: 6px; border: 5px solid #11998e; border-radius: 50%; animation: lds-ring 1.2s cubic-bezier(0.5, 0, 0.5, 1) infinite; border-color: transparent transparent #38ef7d transparent; animation-delay: -0.45s;"></div>
            <div style="box-sizing: border-box; display: block; position: absolute; width: 48px; height: 48px; margin: 6px; border: 5px solid #11998e; border-radius: 50%; animation: lds-ring 1.2s cubic-bezier(0.5, 0, 0.5, 1) infinite; border-color: transparent transparent transparent #11998e; animation-delay: -0.9s;"></div>
          </div>
          <p style="color: #11998e; margin-top: 15px; font-weight: 500;">Loading student details...</p>
        </div>
        <!-- Content Container -->
        <div id="studentModalContent" style="display: none;">
        <div style="background: rgba(255, 255, 255, 0.86); padding: 25px; border-radius: 12px; margin-bottom: 25px; border: 1px solid rgba(224, 224, 224, 0.8);">
          <h3 style="color: #11998e; margin: 0 0 20px 0; font-size: 16px; text-transform: uppercase; letter-spacing: 0.5px; display: flex; align-items: center; gap: 8px; text-decoration: none; border: none;">
            <i class="fas fa-id-card"></i> Registration Information
          </h3>
          <table style="width: 100%; border-collapse: collapse;">
            <tr>
              <td style="padding: 14px 0; font-weight: 600; color: #555; width: 35%;">Full Name</td>
              <td style="padding: 14px 0; padding-left: 15px; color: #333; font-weight: 500;" id="studentModalFullName"></td>
            </tr>
            <tr>
              <td style="padding: 14px 0; font-weight: 600; color: #555;">Email</td>
              <td style="padding: 14px 0; padding-left: 15px; color: #11998e;"><a id="studentModalEmail" href="" style="color: #11998e; text-decoration: none; font-weight: 500;"></a></td>
            </tr>
            <tr>
              <td style="padding: 14px 0; font-weight: 600; color: #555;">Phone Number</td>
              <td style="padding: 14px 0; padding-left: 15px; color: #333; font-weight: 500;" id="studentModalPhone"></td>
            </tr>
            <tr>
              <td style="padding: 14px 0; font-weight: 600; color: #555;">Registered Date</td>
              <td style="padding: 14px 0; padding-left: 15px; color: #333; font-weight: 500;" id="studentModalDate"></td>
            </tr>
            <tr>
              <td style="padding: 14px 0; font-weight: 600; color: #555;">Application Status</td>
              <td style="padding: 14px 0; padding-left: 15px; font-weight: 700; color: #333;" id="studentModalStatus"></td>
            </tr>
            <tr>
              <td style="padding: 14px 0; font-weight: 600; color: #555;">Status Notes</td>
              <td style="padding: 14px 0; padding-left: 15px; color: #333; font-weight: 500;" id="studentModalNotes"></td>
            </tr>
          </table>
        </div>
        <div id="studentSchedulesContainer" style="background: rgba(255, 255, 255, 0.86); padding: 25px; border-radius: 12px; border: 1px solid rgba(224, 224, 224, 0.8);">
          <!-- Schedules will be populated by JavaScript -->
        </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Bulk Status / Delete Confirmation Modal -->
  <div id="bulkConfirmModal" class="modal">
    <div class="modal-content" style="max-width: 520px;">
      <div class="modal-header">
        <i class="fas fa-check-circle"></i>
        Confirm Action
      </div>
      <div class="modal-body">
        <p id="bulkConfirmMessage" class="modal-message"></p>
        <div id="bulkApplicantsList" class="modal-summary-card" style="display: none;">
          <div class="summary-title"><i class="fas fa-users"></i> Selected Applicants</div>
          <ul id="bulkApplicantsListItems"></ul>
        </div>
      </div>
      <div class="modal-actions">
        <button type="button" id="bulkConfirmBtn" class="confirm-delete" style="background: #28a745; border-color: #28a745;">
          <i class="fas fa-check"></i> Confirm
        </button>
        <button type="button" id="bulkCancelBtn" class="cancel-delete">
          <i class="fas fa-times"></i> Cancel
        </button>
      </div>
    </div>
  </div>

  <!-- Bulk Action Success Modal -->
  <div id="bulkSuccessModal" class="modal">
    <div class="modal-content" style="max-width: 520px;">
      <div class="modal-header">
        <i class="fas fa-check-circle"></i>
        Action Completed
      </div>
      <div class="modal-body">
        <p id="bulkSuccessMessage" class="modal-message"></p>
      </div>
      <div class="modal-actions">
        <button type="button" id="bulkSuccessOkBtn" class="confirm-delete" style="background: #28a745; border-color: #28a745;">
          <i class="fas fa-check"></i> OK
        </button>
      </div>
    </div>
  </div>

  <!-- Bulk Processing Loading Overlay -->
  <div id="bulkLoadingOverlay" class="bulk-loading-overlay">
    <div class="bulk-loading-content">
      <div class="bulk-loading-spinner">
        <div class="lds-ring"><div></div><div></div><div></div><div></div></div>
      </div>
      <div class="bulk-loading-text simple-processing">
        <p id="bulkLoadingMessage">Processing...</p>
      </div>
    </div>
  </div>

  <% } %>

  <script src="/js/script.js"></script>
  <script>
    // Student data cache
    const studentDataCache = {};

    async function viewStudent(studentId) {
      console.log('viewStudent called with ID:', studentId);
      
      // Prevent body scrolling
      document.body.style.overflow = 'hidden';
      
      // Show modal with loader immediately
      document.getElementById('studentModal').style.display = 'flex';
      document.getElementById('studentModalBg').style.display = 'flex';
      document.getElementById('studentModalLoader').style.display = 'block';
      document.getElementById('studentModalContent').style.display = 'none';
      
      try {
        // Check cache first
        if (studentDataCache[studentId]) {
          console.log('Loading from cache:', studentId);
          const cachedData = studentDataCache[studentId];
          displayStudentData(cachedData.student, cachedData.studentSchedules);
          return;
        }
        
        // Fetch from API
        console.log('Fetching from API:', `/admin/students/api/${studentId}`);
        const response = await fetch(`/admin/students/api/${studentId}`);
        console.log('Response status:', response.status);
        
        if (!response.ok) {
          console.error('Response not ok:', response.status, response.statusText);
          alert('Failed to load student details: ' + response.status);
          document.getElementById('studentModal').style.display = 'none';
          document.getElementById('studentModalBg').style.display = 'none';
          // Restore body scrolling
          document.body.style.overflow = '';
          return;
        }
        
        const data = await response.json();
        console.log('Received data:', data);
        
        if (!data.student) {
          console.error('No student data in response');
          alert('No student data received');
          document.getElementById('studentModal').style.display = 'none';
          document.getElementById('studentModalBg').style.display = 'none';
          // Restore body scrolling
          document.body.style.overflow = '';
          return;
        }
        
        // Cache the data
        studentDataCache[studentId] = data;
        console.log('Cached student data:', studentId);
        
        // Display the data
        displayStudentData(data.student, data.studentSchedules || []);
        
      } catch (error) {
        console.error('Error loading student details:', error);
        alert('Failed to load student details: ' + error.message);
        document.getElementById('studentModal').style.display = 'none';
        document.getElementById('studentModalBg').style.display = 'none';
        // Restore body scrolling
        document.body.style.overflow = '';
      }
    }

    function displayStudentData(student, schedules) {
      console.log('Displaying student data...');
      
      // Update modal header
      document.getElementById('studentModalName').textContent = student.fullName;
      
      // Update modal content
      document.getElementById('studentModalFullName').textContent = student.fullName;
      document.getElementById('studentModalEmail').textContent = student.email;
      document.getElementById('studentModalEmail').href = `mailto:${student.email}`;
      document.getElementById('studentModalPhone').textContent = student.phoneNumber || 'N/A';
      document.getElementById('studentModalDate').textContent = student.createdAt ? new Date(student.createdAt).toDateString() : 'N/A';
      document.getElementById('studentModalStatus').textContent = student.status || 'pending';
      document.getElementById('studentModalNotes').textContent = student.resultMessage || 'No notes yet.';
      
      // Update schedules
      const schedulesContainer = document.getElementById('studentSchedulesContainer');
      if (schedules.length > 0) {
        let schedulesHtml = `<h3 style="color: #11998e; margin: 0 0 20px 0; font-size: 16px; text-transform: uppercase; letter-spacing: 0.5px; display: flex; align-items: center; gap: 8px;">
          <i class="fas fa-calendar-check"></i> Exam Schedules (${schedules.length})
        </h3>
        <ul style="list-style: none; padding: 0; margin: 0;">`;
        
        schedules.forEach((s, idx) => {
          schedulesHtml += `<li ${idx > 0 ? 'style="padding-top: 15px; margin-top: 15px;"' : ''}>
            <div style="background: linear-gradient(135deg, #f5f5f5 0%, #fafafa 100%); padding: 16px; border-radius: 10px; border-left: 4px solid #11998e;">
              <div style="display: flex; justify-content: space-between; align-items: start;">
                <div style="flex: 1;">
                  <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 8px; color: #11998e; font-weight: 600;">
                    <i class="fas fa-calendar"></i> ${new Date(s.examDate).toDateString()}
                  </div>
                  <div style="display: flex; align-items: center; gap: 8px; color: #555; margin-bottom: 6px; font-size: 14px;">
                    <i class="fas fa-clock"></i> <strong>Time:</strong> ${s.examTime}
                  </div>
                  <div style="display: flex; align-items: center; gap: 8px; color: #555; font-size: 14px;">
                    <i class="fas fa-map-marker-alt"></i> <strong>Location:</strong> ${s.location}
                  </div>
                </div>
              </div>
            </div>
          </li>`;
        });
        
        schedulesHtml += '</ul>';
        schedulesContainer.innerHTML = schedulesHtml;
      } else {
        schedulesContainer.innerHTML = `<div style="background: rgba(255, 255, 255, 0.86); padding: 40px; border-radius: 12px; text-align: center; border: 2px dashed rgba(221, 221, 221, 0.9);">
          <i class="fas fa-calendar-alt" style="font-size: 48px; color: #ccc; display: block; margin-bottom: 12px;"></i>
          <p style="color: #999; margin: 0; font-size: 16px; font-style: italic;">No exam schedules assigned yet</p>
        </div>`;
      }
      
      // Hide loader and show content
      console.log('Showing content, hiding loader');
      document.getElementById('studentModalLoader').style.display = 'none';
      document.getElementById('studentModalContent').style.display = 'block';
    }

    // Search and Filter functionality - Live filtering without page reload
    (function() {
      const searchInput = document.getElementById('studentSearch');
      const statusFilter = document.getElementById('statusFilter');
      const clearBtn = document.getElementById('clearSearch');
      const tableBody = document.querySelector('#studentsGrid tbody');
      
      if (!searchInput || !statusFilter || !tableBody) return;

      // Store original data from page load
      const allRows = Array.from(tableBody.querySelectorAll('tr'));
      const students = allRows.map(row => ({
        row: row,
        name: row.querySelector('.student-name')?.textContent || '',
        email: row.querySelector('.student-email')?.textContent || '',
        status: row.querySelector('.status-badge')?.textContent?.trim().toLowerCase() || 'pending',
        date: row.querySelector('.student-date')?.textContent || ''
      }));

      function filterTable() {
        const searchValue = searchInput.value.trim().toLowerCase();
        const statusValue = statusFilter.value;
        
        let visibleCount = 0;
        
        students.forEach((student, index) => {
          const matchesSearch = searchValue === '' || 
            student.name.toLowerCase().includes(searchValue) ||
            student.email.toLowerCase().includes(searchValue);
          
          const matchesStatus = statusValue === 'all' || student.status.includes(statusValue.toLowerCase());
          
          if (matchesSearch && matchesStatus) {
            student.row.style.display = '';
            visibleCount++;
            // Update index for visible rows
            const indexCell = student.row.querySelector('td:nth-child(2) strong');
            if (indexCell) {
              indexCell.textContent = visibleCount;
            }
          } else {
            student.row.style.display = 'none';
          }
        });

        // Update bulk operations after filtering
        updateSelectAllState();
        updateBulkButtons();
      }

      // Add event listeners for live filtering
      searchInput.addEventListener('input', filterTable);
      statusFilter.addEventListener('change', filterTable);
      
      if (clearBtn) {
        clearBtn.addEventListener('click', () => { 
          searchInput.value = ''; 
          statusFilter.value = 'all';
          filterTable();
          updateSelectAllState();
          updateBulkButtons();
        });
      }
    })();

    // Bulk Operations
    let updateBulkButtons, updateSelectAllState;
    
    (function() {
      const selectAllCheckbox = document.getElementById('selectAll');
      const headerCheckbox = document.getElementById('headerCheckbox');
      const studentCheckboxes = document.querySelectorAll('.student-checkbox');
      const bulkPassBtn = document.getElementById('bulkPassBtn');
      const bulkFailBtn = document.getElementById('bulkFailBtn');
      const bulkDeleteBtn = document.getElementById('bulkDeleteBtn');
      const bulkActionsBar = document.querySelector('.bulk-actions-bar');
      const bulkConfirmModal = document.getElementById('bulkConfirmModal');
      const bulkConfirmMessage = document.getElementById('bulkConfirmMessage');
      const bulkConfirmBtn = document.getElementById('bulkConfirmBtn');
      const bulkCancelBtn = document.getElementById('bulkCancelBtn');
      const bulkSuccessModal = document.getElementById('bulkSuccessModal');
      const bulkSuccessMessage = document.getElementById('bulkSuccessMessage');
      const bulkSuccessOkBtn = document.getElementById('bulkSuccessOkBtn');
      const bulkLoadingOverlay = document.getElementById('bulkLoadingOverlay');
      const bulkLoadingMessage = document.getElementById('bulkLoadingMessage');

      let pendingBulkIds = [];
      let pendingBulkStatus = null;

      if (!bulkActionsBar) return; // No bulk actions bar if no students

      updateBulkButtons = function() {
        const visibleCheckboxes = Array.from(studentCheckboxes).filter(cb => {
          const row = cb.closest('tr');
          return row.style.display !== 'none';
        });
        const checkedBoxes = visibleCheckboxes.filter(cb => cb.checked);
        const hasSelection = checkedBoxes.length > 0;
        
        bulkPassBtn.disabled = !hasSelection;
        bulkFailBtn.disabled = !hasSelection;
        bulkDeleteBtn.disabled = !hasSelection;
        
        bulkPassBtn.style.opacity = hasSelection ? '1' : '0.5';
        bulkFailBtn.style.opacity = hasSelection ? '1' : '0.5';
        bulkDeleteBtn.style.opacity = hasSelection ? '1' : '0.5';
      };

      updateSelectAllState = function() {
        const visibleCheckboxes = Array.from(studentCheckboxes).filter(cb => {
          const row = cb.closest('tr');
          return row.style.display !== 'none';
        });
        
        const checkedVisibleBoxes = visibleCheckboxes.filter(cb => cb.checked);
        const allVisibleChecked = visibleCheckboxes.length > 0 && checkedVisibleBoxes.length === visibleCheckboxes.length;
        const someVisibleChecked = checkedVisibleBoxes.length > 0;
        
        if (selectAllCheckbox) {
          selectAllCheckbox.checked = allVisibleChecked;
          selectAllCheckbox.indeterminate = someVisibleChecked && !allVisibleChecked;
        }
        if (headerCheckbox) {
          headerCheckbox.checked = allVisibleChecked;
          headerCheckbox.indeterminate = someVisibleChecked && !allVisibleChecked;
        }
      };

      function resetBulkConfirmState() {
        bulkConfirmBtn.disabled = false;
        bulkCancelBtn.disabled = false;
        bulkConfirmBtn.classList.remove('loading');
        bulkConfirmBtn.removeAttribute('aria-busy');
        bulkConfirmBtn.innerHTML = '<i class="fas fa-check"></i> Confirm';
      }

      function openBulkConfirm(action, selectedIds) {
        pendingBulkIds = selectedIds;
        pendingBulkStatus = action;

        resetBulkConfirmState();

        // Extract applicant names from table
        const bulkApplicantsList = document.getElementById('bulkApplicantsList');
        const bulkApplicantsListItems = document.getElementById('bulkApplicantsListItems');
        
        const applicantNames = [];
        selectedIds.forEach(id => {
          const checkbox = document.querySelector(`.student-checkbox[value="${id}"]`);
          if (checkbox) {
            const row = checkbox.closest('tr');
            if (row) {
              const nameCell = row.querySelector('.student-name');
              if (nameCell) {
                applicantNames.push(nameCell.textContent.trim());
              }
            }
          }
        });

        // Build applicants list HTML
        if (applicantNames.length > 0) {
          bulkApplicantsListItems.innerHTML = applicantNames
            .map(name => `<li class="summary-list-item"><i class="fas fa-user-check"></i> ${name}</li>`)
            .join('');
          bulkApplicantsList.style.display = 'block';
        } else {
          bulkApplicantsList.style.display = 'none';
        }

        if (action === 'deleted') {
          bulkConfirmMessage.textContent = `You are about to permanently delete ${selectedIds.length} applicant(s). This will also remove all their exam schedules and cannot be undone.`;
          bulkConfirmBtn.innerHTML = '<i class="fas fa-trash"></i> Confirm Delete';
          bulkConfirmBtn.style.background = '#dc3545';
          bulkConfirmBtn.style.borderColor = '#dc3545';
        } else {
          bulkConfirmMessage.textContent = `You are about to mark ${selectedIds.length} applicant(s) as ${action.toUpperCase()}. This will send notification emails to each selected applicant.`;
          bulkConfirmBtn.innerHTML = action === 'passed' ? '<i class="fas fa-check"></i> Confirm Pass' : '<i class="fas fa-times"></i> Confirm Fail';
          bulkConfirmBtn.style.background = action === 'passed' ? '#28a745' : '#dc3545';
          bulkConfirmBtn.style.borderColor = action === 'passed' ? '#28a745' : '#dc3545';
        }

        if (bulkConfirmModal.parentElement !== document.body) {
          document.body.appendChild(bulkConfirmModal);
        }

        document.body.style.overflow = 'hidden';
        bulkConfirmModal.classList.add('show');
      }

      function closeBulkConfirm() {
        pendingBulkIds = [];
        pendingBulkStatus = null;
        bulkConfirmModal.classList.remove('show');
        document.body.style.overflow = '';
        resetBulkConfirmState();
        
        // Clear applicants list
        const bulkApplicantsList = document.getElementById('bulkApplicantsList');
        const bulkApplicantsListItems = document.getElementById('bulkApplicantsListItems');
        if (bulkApplicantsList) bulkApplicantsList.style.display = 'none';
        if (bulkApplicantsListItems) bulkApplicantsListItems.innerHTML = '';
      }

      function showBulkSuccess(message) {
        bulkSuccessMessage.textContent = message;
        // Move modal to body
        if (bulkSuccessModal.parentElement !== document.body) {
          document.body.appendChild(bulkSuccessModal);
        }
        document.body.style.overflow = 'hidden';
        bulkSuccessModal.classList.add('show');
      }

      function closeBulkSuccess() {
        bulkSuccessModal.classList.remove('show');
        document.body.style.overflow = '';
        // Reload the page to show updated data
        window.location.reload();
      }

      function showBulkLoading(message = 'Processing...') {
        bulkLoadingMessage.textContent = message;
        // Move overlay to body
        if (bulkLoadingOverlay.parentElement !== document.body) {
          document.body.appendChild(bulkLoadingOverlay);
        }
        document.body.style.overflow = 'hidden';
        bulkLoadingOverlay.classList.add('show');
      }

      function hideBulkLoading() {
        bulkLoadingOverlay.classList.remove('show');
        document.body.style.overflow = '';
      }

      // Select All functionality
      if (selectAllCheckbox) {
        selectAllCheckbox.addEventListener('change', function() {
          const isChecked = this.checked;
          const visibleCheckboxes = Array.from(studentCheckboxes).filter(cb => {
            const row = cb.closest('tr');
            return row.style.display !== 'none';
          });
          
          visibleCheckboxes.forEach(cb => {
            cb.checked = isChecked;
          });
          
          updateBulkButtons();
        });
      }

      if (headerCheckbox) {
        headerCheckbox.addEventListener('change', function() {
          const isChecked = this.checked;
          const visibleCheckboxes = Array.from(studentCheckboxes).filter(cb => {
            const row = cb.closest('tr');
            return row.style.display !== 'none';
          });
          
          visibleCheckboxes.forEach(cb => {
            cb.checked = isChecked;
          });
          
          updateBulkButtons();
        });
      }

      // Individual checkbox changes
      studentCheckboxes.forEach(cb => {
        cb.addEventListener('change', function() {
          updateSelectAllState();
          updateBulkButtons();
        });
      });

      // Bulk action handlers
      bulkPassBtn.addEventListener('click', function() {
        const visibleCheckboxes = Array.from(document.querySelectorAll('.student-checkbox')).filter(cb => {
          const row = cb.closest('tr');
          return row.style.display !== 'none';
        });
        const selectedIds = visibleCheckboxes.filter(cb => cb.checked).map(cb => cb.value);
        console.log('Bulk Pass clicked - Selected IDs:', selectedIds, 'Length:', selectedIds.length);
        console.log('Visible checkboxes:', visibleCheckboxes.length);
        console.log('Checked visible checkboxes:', visibleCheckboxes.filter(cb => cb.checked).length);
        if (selectedIds.length === 0) {
          console.log('No students selected, returning early');
          return;
        }
        openBulkConfirm('passed', selectedIds);
      });

      bulkFailBtn.addEventListener('click', function() {
        const visibleCheckboxes = Array.from(document.querySelectorAll('.student-checkbox')).filter(cb => {
          const row = cb.closest('tr');
          return row.style.display !== 'none';
        });
        const selectedIds = visibleCheckboxes.filter(cb => cb.checked).map(cb => cb.value);
        console.log('Bulk Fail clicked - Selected IDs:', selectedIds, 'Length:', selectedIds.length);
        console.log('Visible checkboxes:', visibleCheckboxes.length);
        console.log('Checked visible checkboxes:', visibleCheckboxes.filter(cb => cb.checked).length);
        if (selectedIds.length === 0) {
          console.log('No students selected, returning early');
          return;
        }
        openBulkConfirm('failed', selectedIds);
      });

      bulkDeleteBtn.addEventListener('click', function() {
        const visibleCheckboxes = Array.from(document.querySelectorAll('.student-checkbox')).filter(cb => {
          const row = cb.closest('tr');
          return row.style.display !== 'none';
        });
        const selectedIds = visibleCheckboxes.filter(cb => cb.checked).map(cb => cb.value);
        console.log('Bulk Delete clicked - Selected IDs:', selectedIds, 'Length:', selectedIds.length);
        console.log('Visible checkboxes:', visibleCheckboxes.length);
        console.log('Checked visible checkboxes:', visibleCheckboxes.filter(cb => cb.checked).length);
        if (selectedIds.length === 0) {
          console.log('No students selected, returning early');
          return;
        }
        openBulkConfirm('deleted', selectedIds);
      });

      bulkCancelBtn.addEventListener('click', function() {
        closeBulkConfirm();
      });

      bulkSuccessOkBtn.addEventListener('click', function() {
        closeBulkSuccess();
      });

      bulkConfirmBtn.addEventListener('click', async function() {
        console.log('Confirm button clicked, pendingBulkIds:', pendingBulkIds, 'pendingBulkStatus:', pendingBulkStatus);
        if (!pendingBulkIds.length || !pendingBulkStatus || this.disabled) {
          console.log('No pending bulk action or button disabled, returning');
          return;
        }

        const idsToSubmit = [...pendingBulkIds];
        const statusToSubmit = pendingBulkStatus;

        // Prevent duplicate clicks and show actual async state
        this.disabled = true;
        bulkCancelBtn.disabled = true;
        this.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Processing...';
        this.classList.add('loading');
        this.setAttribute('aria-busy', 'true');

        // Close the confirmation modal and show the loading overlay immediately
        closeBulkConfirm();
        showBulkLoading('Processing...');

        try {
          let result;
          if (statusToSubmit === 'deleted') {
            console.log('Calling submitBulkDelete with:', idsToSubmit);
            result = await submitBulkDelete(idsToSubmit);
          } else {
            console.log('Calling submitBulkStatus with:', idsToSubmit, statusToSubmit);
            result = await submitBulkStatus(idsToSubmit, statusToSubmit);
          }

          hideBulkLoading();
          showBulkSuccess(result.message);
        } catch (error) {
          console.error('Bulk operation failed:', error);
          hideBulkLoading();
          resetBulkConfirmState();
          openBulkConfirm(statusToSubmit, idsToSubmit);
          alert('Operation failed: ' + error.message);
        }
      });

      function setBulkStudentInputs(formId, studentIds) {
        const container = document.getElementById(formId);
        container.innerHTML = '';

        studentIds.forEach(id => {
          const input = document.createElement('input');
          input.type = 'hidden';
          input.name = 'studentIds[]';
          input.value = id;
          container.appendChild(input);
        });
      }

      async function submitBulkStatus(studentIds, status) {
        console.log('=== SUBMIT BULK STATUS START ===');
        console.log('Student IDs:', studentIds);
        console.log('Status:', status);
        console.log('IDs length:', studentIds.length);

        if (!studentIds || studentIds.length === 0) {
          throw new Error('No students selected!');
        }

        const response = await fetch('/admin/students/bulk-status', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({ studentIds, status })
        });

        if (!response.ok) {
          const errorText = await response.text();
          throw new Error(`Server error: ${response.status} - ${errorText}`);
        }

        const result = await response.json();
        console.log('Bulk status update result:', result);
        
        return {
          success: true,
          message: result.message || `Successfully updated ${studentIds.length} student(s) to ${status}.`
        };
      }

      async function submitBulkDelete(studentIds) {
        console.log('=== SUBMIT BULK DELETE START ===');
        console.log('Student IDs:', studentIds);
        console.log('IDs length:', studentIds.length);

        if (!studentIds || studentIds.length === 0) {
          throw new Error('No students selected!');
        }

        const response = await fetch('/admin/students/bulk-delete', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({ studentIds })
        });

        if (!response.ok) {
          const errorText = await response.text();
          throw new Error(`Server error: ${response.status} - ${errorText}`);
        }

        const result = await response.json();
        console.log('Bulk delete result:', result);
        
        return {
          success: true,
          message: result.message || `Successfully deleted ${studentIds.length} student(s).`
        };
      }

      // Initialize bulk operations
      updateBulkButtons();
      updateSelectAllState();
    })();

    function closeStudentModal() {
      document.getElementById('studentModal').style.display = 'none';
      document.getElementById('studentModalBg').style.display = 'none';
      // Restore body scrolling
      document.body.style.overflow = '';
    }
  </script>
</body>
</html>