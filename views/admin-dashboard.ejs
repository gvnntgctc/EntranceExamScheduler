<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard</title>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet" />
  <link href="/css/style.css" rel="stylesheet" />
  <style>
    /* Container */
    body, html {
      margin:0; padding:0; height:100%;
      font-family: 'Roboto', sans-serif;
      display: flex;
    }

    .sidebar {
      width: 250px;
      background: #23394d;
      color: white;
      height: 100vh;
      position: fixed;
      padding: 20px;
      box-sizing: border-box;
      z-index: 1000;
    }

    .sidebar .sidebar-header {
      font-size: 20px;
      font-weight: 700;
      margin-bottom: 30px;
      display: flex;
      align-items: center;
    }

    .sidebar .sidebar-menu {
      list-style: none;
      padding: 0;
    }

    .sidebar .sidebar-menu li {
      margin: 15px 0;
    }

    .sidebar .sidebar-menu a {
      color: #cfd8dc;
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 12px 10px;
      border-radius: 6px;
      font-weight: 600;
      font-size: 15px;
      transition: background-color 0.25s, color 0.25s;
      cursor: pointer;
    }

    .sidebar .sidebar-menu a.active, .sidebar .sidebar-menu a:hover {
      background-color: #1CA896;
      color: white;
    }

    /* Main content occupies full page width, under sidebar */
    .main-content {
      margin-left: 250px;
      flex-grow: 1;
      padding: 25px;
      position: relative;
      min-height: 100vh;
      background: #f0f2f5;
    }

    /* Modal styles */
    .modal-overlay {
      position: fixed;
      top: 0; left: 0; right:0; bottom: 0;
      background: rgba(0,0,0,0.5);
      backdrop-filter: blur(4px);
      display: none;
      justify-content: center;
      align-items: center;
      z-index: 2000;
      padding: 15px;
    }
    .modal-overlay.active {
      display: flex;
    }

    .modal {
      background: white;
      border-radius: 16px;
      max-width: 900px;
      width: 100%;
      max-height: 90vh;
      overflow-y: auto;
      box-shadow: 0 12px 30px rgba(0,0,0,0.25);
      padding: 20px 30px;
      animation: slideDown 0.4s ease forwards;
      position: relative;
    }

    @keyframes slideDown {
      from {
        opacity: 0;
        transform: translateY(-30px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .modal-close {
      position: absolute;
      top: 15px;
      right: 20px;
      cursor: pointer;
      font-size: 22px;
      color: #888;
      transition: color 0.3s ease;
    }
    .modal-close:hover {
      color: #333;
    }

    h2 {
      margin-top: 0;
    }

    /* Card grid styles within modal */

    .card-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit,minmax(270px,1fr));
      gap: 25px;
    }

    .card {
      background: white;
      border-radius: 20px;
      box-shadow: 0 6px 20px rgba(0,0,0,0.1);
      cursor: pointer;
      padding: 20px;
      text-align: left;
      transition: box-shadow 0.3s ease, transform 0.3s ease;
      display: flex;
      flex-direction: column;
      min-height: 230px;
    }

    .card:hover {
      transform: translateY(-6px);
      box-shadow: 0 18px 45px rgba(0,0,0,0.15);
    }

    .card-header {
      position: relative;
      padding-bottom: 30px;
      color: white;
      border-radius: 16px 16px 0 0;
      margin-bottom: 20px;
    }

    /* Sample card header colors, adjust as needed */

    .card-header.monday-bg {
      background: linear-gradient(135deg, #3448C3, #4A6AE5);
    }

    .card-header.tuesday-bg {
      background-color: #367CF7;
    }

    .card-header.wednesday-bg {
      background: linear-gradient(135deg, #148193, #0b8075);
    }

    .card-header.thursday-bg {
      background-color: #007E98;
    }

    .card-header.friday-bg {
      background-color: #1D4ED8;
    }

    .card-header h3 {
      margin: 0;
      font-weight: 700;
      font-size: 20px;
      white-space: nowrap;
      text-overflow: ellipsis;
      overflow: hidden;
    }

    .school-logo {
      position: absolute;
      top: -20px;
      right: 20px;
      width: 58px;
      height: 58px;
      border-radius: 50%;
      border: 4px solid white;
      background: white;
      overflow: hidden;
    }

    .school-logo img {
      width: 100%;
      height: 100%;
      object-fit: contain;
    }

    .card-footer {
      border-top: 1px solid #eee;
      padding: 8px 0 0 0;
      color: #666;
      font-size: 22px;
      display: flex;
      gap: 24px;
      justify-content: start;
    }

    .card-footer i:hover {
      color: #1ca896;
      cursor: pointer;
    }

    /* Pagination styles for dashboard */
    .dashboard-pagination {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 20px;
      margin-top: 40px;
      margin-bottom: 20px;
    }
    .pagination-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 44px;
      height: 44px;
      border: 2px solid #ddd;
      background: white;
      border-radius: 8px;
      font-size: 18px;
      cursor: pointer;
      transition: all 0.3s ease;
      color: #333;
    }
    .pagination-btn:hover:not(:disabled) {
      background: #1ca896;
      border-color: #1ca896;
      color: white;
    }
    .pagination-btn:disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }
    .pagination-info {
      font-size: 15px;
      color: #666;
      font-weight: 500;
      min-width: 160px;
      text-align: center;
    }
  </style>
</head>

<body>

  <!-- SIDEBAR OVERLAY -->
  <div class="sidebar-overlay" id="sidebarOverlay"></div>

  <!-- SIDEBAR -->
  <%- include('partials/sidebar') %>

  <!-- MAIN CONTENT -->
  <div class="main-content">

    <h1>Dashboard</h1>

    <div class="card-grid">
      <% schedules.forEach((schedule, index) => { %>
        <% if(schedule.studentId) { %>
          <% 
            const dayClass = schedule.day ? schedule.day.toLowerCase() + '-bg' : 'monday-bg'; 
            const truncatedName = schedule.name.length > 25 ? schedule.name.substring(0, 22) + '...' : schedule.name;
          %>
          <div class="card" style="--animation-order: <%= index %>">
            <div class="card-header <%= dayClass %>">
              <h3 title="<%= schedule.name %>"><%= truncatedName %></h3>
              <small>BSIT 4TL</small>
              <small>LMS Admin</small>
              <div class="school-logo">
                <img src="/images/school-logo.png" alt="School Logo" />
              </div>
            </div>
            <div class="card-footer">
              <i title="Photos" class="fas fa-camera"></i>
              <i title="Files" class="fas fa-folder"></i>
              <i title="More" class="fas fa-ellipsis-h"></i>
            </div>
          </div>
        <% } %>
      <% }) %>
    </div>

    <!-- PAGINATION CONTROLS -->
    <% if (schedules.filter(s => s.studentId).length > 20) { %>
      <div class="dashboard-pagination">
        <button class="pagination-btn" id="prevBtn" onclick="previousPage()" title="Previous Page">
          <i class="fas fa-chevron-left"></i>
        </button>
        <div class="pagination-info">
          <span id="pageInfo">Page 1</span>
        </div>
        <button class="pagination-btn" id="nextBtn" onclick="nextPage()" title="Next Page">
          <i class="fas fa-chevron-right"></i>
        </button>
      </div>
    <% } %>

  <script src="/js/script.js"></script>
  <script>
    // Sidebar toggle
    const hamburger = document.getElementById('hamburger');
    const sidebar = document.getElementById('sidebar');
    const sidebarClose = document.getElementById('sidebarClose');
    const sidebarOverlay = document.getElementById('sidebarOverlay');

    if (hamburger && sidebar && sidebarClose) {
      hamburger.addEventListener('click', () => {
        sidebar.classList.toggle('open');
        hamburger.classList.toggle('active');
        sidebarOverlay.classList.toggle('active');
        sidebarClose.classList.toggle('visible');
      });

      sidebarClose.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        sidebar.classList.remove('open');
        hamburger.classList.remove('active');
        sidebarOverlay.classList.remove('active');
        sidebarClose.classList.remove('visible');
      });
    }

    if (sidebarOverlay) {
      sidebarOverlay.addEventListener('click', () => {
        sidebar.classList.remove('open');
        hamburger.classList.remove('active');
        sidebarOverlay.classList.remove('active');
        sidebarClose.classList.remove('visible');
      });
    }

    // Card click
    document.querySelectorAll('.card').forEach(card => {
      card.addEventListener('click', () => {
        // Redirect or modal for details
        alert('You clicked card: ' + card.querySelector('h3').textContent);
      });
    });

    // PAGINATION FOR DASHBOARD CARDS
    const ITEMS_PER_PAGE = 10;
    let currentPage = 1;
    const cardGrid = document.querySelector('.card-grid');
    let allCards = [];

    if (cardGrid) {
      allCards = Array.from(cardGrid.querySelectorAll('.card'));
      if (allCards.length > ITEMS_PER_PAGE) {
        displayPage(currentPage);
        updatePaginationButtons();
      }
    }

    function displayPage(pageNumber) {
      const startIndex = (pageNumber - 1) * ITEMS_PER_PAGE;
      const endIndex = startIndex + ITEMS_PER_PAGE;

      allCards.forEach((card, index) => {
        card.style.display = (index >= startIndex && index < endIndex) ? '' : 'none';
      });

      // Update page info
      const totalPages = Math.ceil(allCards.length / ITEMS_PER_PAGE);
      const pageInfoEl = document.getElementById('pageInfo');
      if (pageInfoEl) {
        pageInfoEl.textContent = `Page ${pageNumber} of ${totalPages}`;
      }
    }

    function updatePaginationButtons() {
      const totalPages = Math.ceil(allCards.length / ITEMS_PER_PAGE);
      const prevBtn = document.getElementById('prevBtn');
      const nextBtn = document.getElementById('nextBtn');

      if (prevBtn) {
        prevBtn.disabled = currentPage === 1;
      }
      if (nextBtn) {
        nextBtn.disabled = currentPage === totalPages;
      }
    }

    function nextPage() {
      const totalPages = Math.ceil(allCards.length / ITEMS_PER_PAGE);
      if (currentPage < totalPages) {
        currentPage++;
        displayPage(currentPage);
        updatePaginationButtons();
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }
    }

    function previousPage() {
      if (currentPage > 1) {
        currentPage--;
        displayPage(currentPage);
        updatePaginationButtons();
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }
    }
  </script>
</body>
</html>