<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="admin-page-bg">
  <%- include('partials/sidebar', { page: 'dashboard' }) %>
  <div class="sidebar-overlay" id="sidebarOverlay"></div>
  <button class="hamburger" id="hamburger" aria-label="Open menu"><i class="fas fa-bars"></i></button>
  <div class="main-content">
    <div class="page-logo"><img src="/images/logo.png" alt="PTC Logo" /></div>
    <div class="container">
      <h1><i class="fas fa-chart-pie"></i> Dashboard</h1>
      <div class="section-card">
        <div class="stats-grid">
          <div class="stat-card"><span>Total applicants</span><strong><%= metrics.totalApplicants %></strong></div>
          <div class="stat-card"><span>Pending review</span><strong><%= metrics.pendingReview %></strong></div>
          <div class="stat-card"><span>Scheduled</span><strong><%= metrics.scheduled %></strong></div>
          <div class="stat-card"><span>Passed</span><strong><%= metrics.passed %></strong></div>
          <div class="stat-card"><span>Failed</span><strong><%= metrics.failed %></strong></div>
          <div class="stat-card"><span>Remaining slots</span><strong><%= metrics.remainingSlots %></strong></div>
        </div>
      </div>
      <div class="section-card">
        <h2><i class="fas fa-fire"></i> Busiest Slots</h2>
        <% if (!metrics.busiest.length) { %>
          <div class="no-data"><p>No schedules are inside the configured cycle yet.</p></div>
        <% } else { %>
          <table class="schedule-table">
            <thead><tr><th>Date</th><th>Room</th><th>Time</th><th>Booked</th></tr></thead>
            <tbody>
              <% metrics.busiest.forEach(item => { %>
                <tr><td><%= item.date %></td><td><%= item.room %></td><td><%= item.timeSlot %></td><td><%= item.count %></td></tr>
              <% }) %>
            </tbody>
          </table>
        <% } %>
      </div>
    </div>
  </div>
  <script src="/js/script.js"></script>
</body>
</html>
