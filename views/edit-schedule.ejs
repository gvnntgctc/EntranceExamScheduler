<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Edit Schedule - Exam Scheduler</title>
  <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
   <%- include('partials/sidebar') %>

  <!-- Overlay -->
  <div class="sidebar-overlay" id="sidebarOverlay"></div>
  
  <!-- Hamburger Button -->
  <button class="hamburger" id="hamburger"><i class="fas fa-bars"></i></button>
  
  <!-- Sidebar -->
  <div class="sidebar" id="sidebar">
    <button class="sidebar-close" id="sidebarClose"><i class="fas fa-times"></i></button>
    
    <div class="sidebar-header">
      <h2><i class="fas fa-cogs"></i> Admin Panel</h2>
    </div>
    <ul class="sidebar-menu">
      <li><a href="/admin"><i class="fas fa-tachometer-alt"></i> Dashboard</a></li>
      <li><a href="/admin#add-schedule"><i class="fas fa-plus-circle"></i> Add Schedule</a></li>
      <li><a href="/admin#schedules"><i class="fas fa-calendar-alt"></i> View Schedules</a></li>
      <li><a href="/admin/students"><i class="fas fa-users"></i> Students</a></li>
      <li><a href="/auth/logout"><i class="fas fa-sign-out-alt"></i> Logout</a></li>
    </ul>
  </div>
  
  <!-- Main Content -->
  <div class="main-content">
    <div class="container">
      <h1><i class="fas fa-edit"></i> Edit Schedule</h1>
      
      <% if (error && error.length > 0) { %>
        <div class="message error">
          <i class="fas fa-exclamation-triangle"></i> <%= error %>
        </div>
      <% } %>
      
      <div class="section-card">
        <h2><i class="fas fa-calendar-alt"></i> Update Schedule Details</h2>
        <form action="/admin/edit-schedule/<%= schedule._id %>" method="POST" class="schedule-form">
          <div class="form-group">
            <label for="studentName"><i class="fas fa-user"></i> Applicant Name</label>
            <input type="text" id="studentName" name="studentName" value="<%= schedule.studentId ? schedule.studentId.fullName : '' %>" disabled />
            <small class="sub-text">This is a specific applicant's schedule</small>
          </div>
          
          <div class="form-group">
            <label for="examDate"><i class="fas fa-calendar"></i> Exam Date</label>
            <input type="date" id="examDate" name="examDate" value="<%= schedule.examDate ? new Date(schedule.examDate).toISOString().split('T')[0] : '' %>" required>
          </div>
          
          <div class="form-group">
            <label for="examTime"><i class="fas fa-clock"></i> Exam Time</label>
            <select id="examTime" name="examTime" required aria-required="true" aria-label="Select exam time slot">
              <option value="">Choose a time slot</option>
              <option value="7:00-8:30 A.M" <% if(schedule.examTime === '7:00-8:30 A.M') { %>selected<% } %>>7:00-8:30 A.M</option>
              <option value="9:00-10:30 A.M" <% if(schedule.examTime === '9:00-10:30 A.M') { %>selected<% } %>>9:00-10:30 A.M</option>
              <option value="1:30-3:00 P.M" <% if(schedule.examTime === '1:30-3:00 P.M') { %>selected<% } %>>1:30-3:00 P.M</option>
              <option value="3:30-5:00 P.M" <% if(schedule.examTime === '3:30-5:00 P.M') { %>selected<% } %>>3:30-5:00 P.M</option>
            </select>
            <small class="sub-text">Select a time slot for the applicant's exam.</small>
          </div>
          
          <div class="form-group">
            <label for="location"><i class="fas fa-map-marker-alt"></i> Location</label>
            <input type="text" id="location" name="location" value="<%= schedule.location || '3rd Floor PTC Main Campus' %>" disabled />
            <input type="hidden" name="location" value="<%= schedule.location || '3rd Floor PTC Main Campus' %>" />
            <small class="sub-text">Fixed location for all exams</small>
          </div>
          
          <div class="form-buttons">
            <button type="submit" class="btn btn-primary">
              <i class="fas fa-save"></i> Update Schedule
            </button>
            <a href="/admin/weekly-schedule" class="btn btn-secondary">
              <i class="fas fa-arrow-left"></i> Cancel
            </a>
          </div>
        </form>
      </div>
    </div>
  </div>
  
  <script src="/js/script.js"></script>
</body>
</html>