<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Add Schedule - Exam Scheduler</title>
  <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .bulk-applicant-group {
      grid-column: 1 / -1;
    }

    .bulk-selector {
      display: grid;
      gap: 12px;
      padding: 14px;
      border: 1px solid rgba(197, 214, 205, 0.9);
      border-radius: 14px;
      background: #fbfdfb;
      box-shadow: 0 12px 28px rgba(15, 23, 42, 0.06);
    }

    .bulk-selector-toolbar {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 10px;
      align-items: center;
    }

    .bulk-search-wrap {
      display: flex;
      align-items: center;
      gap: 10px;
      min-height: 48px;
      padding: 0 12px;
      border: 1px solid #dce8e2;
      border-radius: 12px;
      background: #ffffff;
    }

    .bulk-search-wrap i {
      color: #11998e;
    }

    .bulk-search-wrap .search-input {
      width: 100%;
      height: 46px;
      padding: 0;
      border: 0;
      outline: 0;
      background: transparent;
      box-shadow: none;
    }

    .bulk-select-all-btn,
    .clear-selected-btn {
      border: 0;
      border-radius: 12px;
      cursor: pointer;
      font-weight: 700;
      transition: transform 0.2s ease, filter 0.2s ease;
    }

    .bulk-select-all-btn {
      min-height: 48px;
      padding: 0 16px;
      background: #1b6f28;
      color: #ffffff;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      white-space: nowrap;
    }

    .bulk-select-all-btn:hover,
    .clear-selected-btn:hover {
      filter: brightness(0.98);
      transform: translateY(-1px);
    }

    .bulk-selector-meta {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 10px;
      min-height: 34px;
      padding: 8px 10px;
      border-radius: 10px;
      color: #476052;
      background: #f3f8f5;
      font-size: 13px;
      font-weight: 700;
    }

    .clear-selected-btn {
      padding: 7px 12px;
      background: #ffffff;
      color: #1b6f28;
      box-shadow: inset 0 0 0 1px #dce8e2;
    }

    .schedule-form .bulk-selector .bulk-applicant-list {
      max-height: 250px;
      overflow-y: auto;
      display: grid;
      gap: 8px;
      padding: 4px 4px 4px 0;
    }

    .schedule-form .bulk-selector .bulk-applicant-option {
      position: relative;
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 14px;
      align-items: center;
      min-height: 66px;
      padding: 12px 14px;
      border: 1px solid #e1ece5;
      border-radius: 12px;
      background: #ffffff;
      cursor: pointer;
      margin: 0;
      color: inherit;
      transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
    }

    .schedule-form .bulk-selector .bulk-applicant-option:hover,
    .schedule-form .bulk-selector .bulk-applicant-option.is-selected {
      border-color: #1b6f28;
      box-shadow: 0 10px 22px rgba(27, 111, 40, 0.09);
    }

    .schedule-form .bulk-selector .bulk-applicant-option.is-selected {
      background: #f0faf3;
    }

    .schedule-form .bulk-selector .bulk-applicant-option input {
      position: absolute;
      width: 1px;
      height: 1px;
      margin: 0;
      padding: 0;
      opacity: 0;
      pointer-events: none;
    }

    .bulk-applicant-name {
      display: block;
      color: #25342a;
      font-weight: 700;
      overflow-wrap: anywhere;
    }

    .bulk-applicant-email {
      display: block;
      margin-top: 3px;
      color: #64766b;
      font-size: 12px;
      overflow-wrap: anywhere;
    }

    .bulk-applicant-status {
      width: 28px;
      height: 28px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 50%;
      background: #eef8f2;
      color: #11998e;
      font-size: 14px;
      transition: background 0.2s ease, color 0.2s ease, transform 0.2s ease;
    }

    .schedule-form .bulk-selector .bulk-applicant-option.is-selected .bulk-applicant-status {
      background: #1b6f28;
      color: #ffffff;
      transform: scale(1.03);
    }

    .selected-applicants-panel {
      border-top: 1px solid #e2ece6;
      padding-top: 12px;
    }

    .selected-applicants-title {
      display: flex;
      justify-content: space-between;
      gap: 10px;
      margin-bottom: 10px;
      color: #25342a;
      font-weight: 700;
    }

    .selected-applicants-title small {
      color: #718279;
      font-weight: 600;
    }

    .selected-applicants-list {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      min-height: 40px;
      max-height: 104px;
      overflow-y: auto;
    }

    .selected-applicant-chip {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      max-width: 100%;
      padding: 8px 10px;
      border-radius: 999px;
      background: #eaf7ef;
      color: #1b5e20;
      font-size: 13px;
      font-weight: 700;
      border: 1px solid #d2ead9;
    }

    .selected-applicant-chip span {
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .selected-applicant-chip button {
      border: 0;
      background: transparent;
      color: #1b5e20;
      cursor: pointer;
      padding: 0;
      display: inline-flex;
      align-items: center;
    }

    .bulk-empty {
      width: 100%;
      padding: 18px;
      border: 1px dashed #d6e4dc;
      border-radius: 12px;
      text-align: center;
      color: #718279;
      background: #fbfdfb;
      font-weight: 600;
    }

    @media (max-width: 720px) {
      .bulk-selector-toolbar {
        grid-template-columns: 1fr;
      }

      .bulk-select-all-btn {
        justify-content: center;
        width: 100%;
      }

      .selected-applicants-title {
        flex-direction: column;
      }

      .schedule-form .bulk-selector .bulk-applicant-option {
        grid-template-columns: 1fr auto;
      }
    }
  </style>
</head>
<body class="admin-page-bg">
  <%- include('partials/sidebar') %>

  <!-- Overlay -->
  <div class="sidebar-overlay" id="sidebarOverlay"></div>
  
  <!-- Hamburger Button -->
  <button class="hamburger" id="hamburger"><i class="fas fa-bars"></i></button>
  
  <!-- Main Content -->
  <div class="main-content">
    <div class="page-logo">
      <img src="/images/logo.png" alt="PTC Logo" />
    </div>
    <div class="container add-schedule-shell">
      <h1><i class="fas fa-plus-circle"></i> Add New Schedule</h1>
      
      
      <% if (error && error.length > 0) { %>
        <div class="message error">
          <i class="fas fa-exclamation-triangle"></i> <%= error %>
        </div>
      <% } %>

      <% if (success && success.length > 0) { %>
        <div class="message success">
          <i class="fas fa-check-circle"></i> <%= success %>
        </div>
      <% } %>

      <div class="section-card">
        <div class="stats-grid">
          <div class="stat-card">
            <span>Total applicants</span>
            <strong><%= students ? students.length : 0 %></strong>
          </div>
          <div class="stat-card">
            <span>Total schedules</span>
            <strong><%= schedules ? schedules.length : 0 %></strong>
          </div>
          <div class="stat-card">
            <span>Upcoming exams</span>
            <strong><%= schedules ? schedules.filter(s => new Date(s.examDate) >= new Date()).length : 0 %></strong>
          </div>
        </div>
        <h2><i class="fas fa-calendar-plus"></i> Create Schedule</h2>
        <form action="/admin/add-schedule" method="POST" class="schedule-form" role="form" aria-label="Add schedule form">
          <div class="form-grid">
            <div class="form-group bulk-applicant-group">
              <label for="studentSearch"><i class="fas fa-users"></i> Applicants</label>
              <% if (students && students.length > 0) { %>
                <div class="bulk-selector" data-total-applicants="<%= students.length %>">
                  <div class="bulk-selector-toolbar">
                    <div class="bulk-search-wrap">
                      <i class="fas fa-search"></i>
                      <input type="search" id="studentSearch" class="search-input" placeholder="Search applicants by name or email" autocomplete="off" aria-label="Search applicants" />
                    </div>
                    <button type="button" class="bulk-select-all-btn" id="selectAllApplicantsBtn">
                      <i class="fas fa-check-double"></i> Select All
                    </button>
                  </div>
                  <div class="bulk-selector-meta">
                    <span id="selectedApplicantCount">0 selected</span>
                    <button type="button" id="clearSelectedApplicantsBtn" class="clear-selected-btn">Clear</button>
                  </div>
                  <div class="bulk-applicant-list" id="studentSuggestions" role="listbox" aria-label="Applicant options"></div>
                  <div class="selected-applicants-panel" id="selectedApplicantsPanel">
                    <div class="selected-applicants-title">
                      <span><i class="fas fa-user-check"></i> Selected Applicants</span>
                      <small id="selectedApplicantsHint">Choose one or more applicants.</small>
                    </div>
                    <div class="selected-applicants-list" id="selectedApplicantsList"></div>
                  </div>
                  <input type="hidden" name="bulkMode" value="1" />
                  <div id="selectedStudentInputs"></div>
                </div>
                <small class="sub-text">Select one or more applicants without an existing schedule. All selected applicants receive the same date, time, and room.</small>
              <% } else { %>
                <input type="text" id="studentId" name="studentId" placeholder="Enter applicant name or email" required aria-label="Applicant name or email" autocomplete="off" />
              <% } %>
            </div>

            <div class="form-group exam-date-container">
              <label for="examDateDisplay"><i class="fas fa-calendar"></i> Exam Date</label>
              <div class="exam-date-card">
                <input type="hidden" id="examDate" name="examDate" />
                <input type="text" id="examDateDisplay" placeholder="Click to choose a date from March to August 2026" readonly required aria-label="Selected exam date" aria-describedby="holidayHelp capacityWarning" />
              </div>
              <small class="sub-text" id="holidayHelp">Click the field to open the exam date picker.</small>
            </div>

            <div class="form-group">
              <label for="examTime"><i class="fas fa-clock"></i> Exam Time</label>
              <select id="examTime" name="examTime" required aria-required="true" aria-label="Select exam time slot">
                <option value="">Choose a time slot</option>
                <option value="7:00-8:30 A.M">7:00-8:30 A.M</option>
                <option value="9:00-10:30 A.M">9:00-10:30 A.M</option>
                <option value="1:30-3:00 P.M">1:30-3:00 P.M</option>
                <option value="3:30-5:00 P.M">3:30-5:00 P.M</option>
              </select>
              <small class="sub-text">Select a time slot for the applicant's exam.</small>
            </div>

            <div class="form-group">
              <label for="location"><i class="fas fa-map-marker-alt"></i> Location</label>
              <select id="location" name="location" required aria-required="true" aria-label="Select exam location">
                <option value="">Select Exam Location</option>
                <option value="3rd Floor Room 301 PTC Main Campus">3rd Floor Room 301 PTC Main Campus</option>
                <option value="3rd Floor Room 302 PTC Main Campus">3rd Floor Room 302 PTC Main Campus</option>
                <option value="3rd Floor Room 303 PTC Main Campus">3rd Floor Room 303 PTC Main Campus</option>
              </select>
              <small class="sub-text">Choose one of the predefined exam rooms.</small>
            </div>
          </div>

          <div class="holiday-panel"></div>
          <p id="holidayWarning" class="holiday-warning" aria-live="polite"></p>
          <p id="capacityWarning" class="holiday-warning" aria-live="polite"></p>

          <div class="form-buttons">
            <button type="submit" class="btn btn-primary"><i class="fas fa-plus"></i> Add Schedule</button>
            <a href="/admin/weekly-schedule" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Cancel</a>
          </div>
        </form>
      </div>

      <div class="section-card">
        <div class="section-header">
          <h2><i class="fas fa-list"></i> Existing Schedules</h2>
          <span class="student-count"><%= schedules && schedules.length ? schedules.length : 0 %> scheduled</span>
        </div>
        <% if (schedules && schedules.length) { %>
          <!-- Search Bar -->
          <div class="search-bar-container">
            <div class="search-container">
              <i class="fas fa-search"></i>
              <input 
                type="text" 
                id="scheduleSearch" 
                class="search-input" 
                placeholder="Search by applicant name, email, date, or location..."
              />
            </div>
          </div>

          <div class="table-responsive">
            <table class="schedule-table">
              <thead>
                <tr>
                  <th>#</th>
                  <th>Applicant</th>
                  <th>Date</th>
                  <th>Time</th>
                  <th>Location</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody id="schedulesList">
                <% schedules.forEach((s, index) => { %>
                  <tr class="schedule-row">
                    <td class="row-index"><%= index + 1 %></td>
                    <td>
                      <div class="schedule-applicant-cell">
                        <strong><%= s.studentId ? s.studentId.fullName : 'Unknown Applicant' %></strong>
                        <span class="applicant-email"><%= s.studentId ? s.studentId.email : 'No email available' %></span>
                      </div>
                    </td>
                    <td><%= new Date(s.examDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></td>
                    <td><%= s.examTime %></td>
                    <td><%= s.location %></td>
                    <td class="schedule-actions">
                      <a href="/admin/edit-schedule/<%= s._id %>" class="edit-btn circle-btn" title="Edit schedule"><i class="fas fa-edit"></i></a>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
          
          <!-- Pagination Controls -->
          <div class="pagination-controls">
            <button class="pagination-btn" id="prevBtn" onclick="previousPage()">
              <i class="fas fa-chevron-left"></i> Previous
            </button>
            <span class="page-info" id="pageInfo">Page 1</span>
            <button class="pagination-btn" id="nextBtn" onclick="nextPage()">
              Next <i class="fas fa-chevron-right"></i>
            </button>
          </div>
        <% } else { %>
          <div class="no-data">
            <i class="fas fa-calendar-times"></i>
            
          </div>
        <% } %>
      </div>
    </div>
  </div>

  <% if (success || (error && error.length > 0)) { %>
    <div id="toastMessage" class="toast-message <%= success ? 'toast-success' : 'toast-error' %>" role="status" aria-live="polite">
      <span class="toast-icon"><i class="fas <%= success ? 'fa-check-circle' : 'fa-exclamation-circle' %>"></i></span>
      <div class="toast-content"><%= success || error %></div>
      <button type="button" class="toast-close" aria-label="Close notification">&times;</button>
    </div>
  <% } %>

  <div class="modal-overlay" id="examDateModal" aria-hidden="true">
    <div class="modal-content" role="dialog" aria-modal="true" aria-labelledby="examDateModalTitle">
      <div class="modal-header">
        <h2 id="examDateModalTitle">Select Exam Date</h2>
        <button type="button" class="modal-back" id="examDateModalClose">Close</button>
      </div>
      <div class="modal-body">
        <div class="calendar-banner">
          <button type="button" id="prevMonth" aria-label="Previous month">‹</button>
          <div class="calendar-title" id="calendarTitle">March 2026</div>
          <button type="button" id="nextMonth" aria-label="Next month">›</button>
        </div>
        <div class="weekday-row" aria-hidden="true">
          <span>Sun</span><span>Mon</span><span>Tue</span><span>Wed</span><span>Thu</span><span>Fri</span><span>Sat</span>
        </div>
        <div class="date-grid" id="dateGrid" aria-live="polite"></div>
      </div>
    </div>
  </div>

  <div class="modal-overlay" id="deleteConfirmModal" aria-hidden="true">
    <div class="modal-content" role="dialog" aria-modal="true" aria-labelledby="deleteModalTitle">
      <div class="modal-header">
        <h2 id="deleteModalTitle">Confirm Delete</h2>
      </div>
      <div class="modal-body">
        <p id="deleteModalMessage">Are you sure you want to delete this schedule? This action cannot be undone.</p>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" id="deleteModalCancel">Cancel</button>
        <button type="button" class="btn delete-btn" id="deleteModalConfirm">Delete Schedule</button>
      </div>
    </div>
  </div>

  <script id="scheduleData" type="application/json">{"scheduleCounts":<%- JSON.stringify(scheduleCounts || {}) %>,"students":<%- JSON.stringify(students || []) %>}</script>
  <script>
    const scheduleData = JSON.parse(document.getElementById('scheduleData').textContent || '{}');
    const scheduleCounts = scheduleData.scheduleCounts || {};
    const toastMessage = document.getElementById('toastMessage');
    if (toastMessage) {
      toastMessage.classList.add('show');
      const toastClose = toastMessage.querySelector('.toast-close');
      toastClose?.addEventListener('click', () => toastMessage.classList.remove('show'));
      setTimeout(() => toastMessage.classList.remove('show'), 4500);
    }

    const deleteConfirmModal = document.getElementById('deleteConfirmModal');
    const deleteModalMessage = document.getElementById('deleteModalMessage');
    const deleteModalCancel = document.getElementById('deleteModalCancel');
    const deleteModalConfirm = document.getElementById('deleteModalConfirm');
    let pendingDeleteUrl = null;

    document.querySelectorAll('.delete-trigger').forEach(button => {
      button.addEventListener('click', function(event) {
        event.preventDefault();
        pendingDeleteUrl = button.dataset.deleteUrl;
        const title = button.dataset.scheduleTitle || 'this schedule';
        const date = button.dataset.scheduleDate || '';
        deleteModalMessage.textContent = date
          ? `Are you sure you want to delete ${title}'s schedule on ${date}? This action cannot be undone.`
          : 'Are you sure you want to delete this schedule? This action cannot be undone.';
        deleteConfirmModal.classList.add('active');
        deleteConfirmModal.setAttribute('aria-hidden', 'false');
      });
    });

    function closeDeleteModal() {
      deleteConfirmModal.classList.remove('active');
      deleteConfirmModal.setAttribute('aria-hidden', 'true');
      pendingDeleteForm = null;
    }

    deleteModalCancel?.addEventListener('click', closeDeleteModal);
    deleteConfirmModal?.addEventListener('click', function(event) {
      if (event.target === deleteConfirmModal) {
        closeDeleteModal();
      }
    });
    deleteModalConfirm?.addEventListener('click', function() {
      if (pendingDeleteUrl) {
        const form = document.createElement('form');
        form.method = 'POST';
        form.action = pendingDeleteUrl;
        document.body.appendChild(form);
        form.submit();
      }
    });

    // Bulk applicant multi-select
    const studentOptions = (scheduleData.students || []).filter(student => student.status === 'pending');
    const studentSearchInput = document.getElementById('studentSearch');
    const studentSuggestions = document.getElementById('studentSuggestions');
    const selectedStudentInputs = document.getElementById('selectedStudentInputs');
    const selectedApplicantsList = document.getElementById('selectedApplicantsList');
    const selectedApplicantCount = document.getElementById('selectedApplicantCount');
    const selectedApplicantsHint = document.getElementById('selectedApplicantsHint');
    const selectAllApplicantsBtn = document.getElementById('selectAllApplicantsBtn');
    const clearSelectedApplicantsBtn = document.getElementById('clearSelectedApplicantsBtn');
    const selectedApplicantIds = new Set();

    function getFilteredApplicants() {
      const normalized = (studentSearchInput?.value || '').trim().toLowerCase();
      return studentOptions.filter(student => {
        const label = `${student.fullName || ''} ${student.email || ''}`.toLowerCase();
        return normalized === '' || label.includes(normalized);
      });
    }

    function syncSelectedInputs() {
      if (!selectedStudentInputs) return;
      selectedStudentInputs.innerHTML = '';
      selectedApplicantIds.forEach(id => {
        const input = document.createElement('input');
        input.type = 'hidden';
        input.name = 'studentIds[]';
        input.value = id;
        selectedStudentInputs.appendChild(input);
      });
    }

    function renderSelectedApplicants() {
      if (!selectedApplicantsList || !selectedApplicantCount) return;
      const selectedStudents = studentOptions.filter(student => selectedApplicantIds.has(String(student._id)));
      selectedApplicantCount.textContent = `${selectedStudents.length} selected`;
      if (selectedApplicantsHint) {
        selectedApplicantsHint.textContent = selectedStudents.length
          ? 'Remove anyone who should not receive this schedule.'
          : 'Choose one or more applicants.';
      }

      selectedApplicantsList.innerHTML = '';
      if (selectedStudents.length === 0) {
        const empty = document.createElement('div');
        empty.className = 'bulk-empty';
        empty.textContent = 'No applicants selected yet.';
        selectedApplicantsList.appendChild(empty);
        syncSelectedInputs();
        return;
      }

      selectedStudents.forEach(student => {
        const chip = document.createElement('span');
        chip.className = 'selected-applicant-chip';
        const icon = document.createElement('i');
        icon.className = 'fas fa-user';
        const label = document.createElement('span');
        label.textContent = student.fullName || student.email;
        const removeBtn = document.createElement('button');
        removeBtn.type = 'button';
        removeBtn.setAttribute('aria-label', `Remove ${student.fullName || student.email}`);
        removeBtn.innerHTML = '<i class="fas fa-times"></i>';
        removeBtn.addEventListener('click', () => {
          selectedApplicantIds.delete(String(student._id));
          renderApplicantOptions();
          renderSelectedApplicants();
        });
        chip.appendChild(icon);
        chip.appendChild(label);
        chip.appendChild(removeBtn);
        selectedApplicantsList.appendChild(chip);
      });
      syncSelectedInputs();
    }

    function renderApplicantOptions() {
      if (!studentSuggestions) return;
      studentSuggestions.innerHTML = '';
      const filteredApplicants = getFilteredApplicants();

      if (filteredApplicants.length === 0) {
        const empty = document.createElement('div');
        empty.className = 'bulk-empty';
        empty.textContent = 'No applicants match your search.';
        studentSuggestions.appendChild(empty);
        return;
      }

      filteredApplicants.forEach(student => {
        const id = String(student._id);
        const option = document.createElement('label');
        option.className = `bulk-applicant-option${selectedApplicantIds.has(id) ? ' is-selected' : ''}`;
        const checkbox = document.createElement('input');
        checkbox.type = 'checkbox';
        checkbox.value = id;
        checkbox.checked = selectedApplicantIds.has(id);
        const textWrap = document.createElement('span');
        const name = document.createElement('span');
        name.className = 'bulk-applicant-name';
        name.textContent = student.fullName || 'Unnamed Applicant';
        const email = document.createElement('span');
        email.className = 'bulk-applicant-email';
        email.textContent = student.email || 'No email available';
        const statusIcon = document.createElement('i');
        statusIcon.className = `bulk-applicant-status fas ${selectedApplicantIds.has(id) ? 'fa-check' : 'fa-plus'}`;
        statusIcon.setAttribute('aria-hidden', 'true');
        textWrap.appendChild(name);
        textWrap.appendChild(email);
        option.appendChild(checkbox);
        option.appendChild(textWrap);
        option.appendChild(statusIcon);
        checkbox.addEventListener('change', (event) => {
          if (event.target.checked) {
            selectedApplicantIds.add(id);
          } else {
            selectedApplicantIds.delete(id);
          }
          renderApplicantOptions();
          renderSelectedApplicants();
        });
        studentSuggestions.appendChild(option);
      });
    }

    if (studentSearchInput) {
      studentSearchInput.addEventListener('input', renderApplicantOptions);
      selectAllApplicantsBtn?.addEventListener('click', () => {
        getFilteredApplicants().forEach(student => selectedApplicantIds.add(String(student._id)));
        renderApplicantOptions();
        renderSelectedApplicants();
      });
      clearSelectedApplicantsBtn?.addEventListener('click', () => {
        selectedApplicantIds.clear();
        renderApplicantOptions();
        renderSelectedApplicants();
      });
      renderApplicantOptions();
      renderSelectedApplicants();
    }
  </script>
  <script src="/js/script.js"></script>
  <script>
    // PAGINATION FOR EXISTING SCHEDULES
    const ITEMS_PER_PAGE = 10;
    let currentPage = 1;
    const schedulesList = document.getElementById('schedulesList');
    let allSchedules = [];
    let originalScheduleOrder = [];

    if (schedulesList) {
      allSchedules = Array.from(schedulesList.querySelectorAll('tr.schedule-row'));
      originalScheduleOrder = [...allSchedules];
      
      // Initialize all schedules with dataset.hidden = 'false'
      allSchedules.forEach(item => {
        item.dataset.hidden = 'false';
        item.style.display = 'none'; // Hide all initially
      });
      
      // Define displayPage function first
      function displayPage(pageNumber) {
        const visibleSchedules = allSchedules.filter(item => item.dataset.hidden !== 'true');
        
        const startIndex = (pageNumber - 1) * ITEMS_PER_PAGE;
        const endIndex = startIndex + ITEMS_PER_PAGE;
        
        allSchedules.forEach(item => {
          item.style.display = 'none';
        });
        
        visibleSchedules.slice(startIndex, endIndex).forEach(item => {
          item.style.display = 'table-row';
        });

        const totalPages = Math.max(1, Math.ceil(visibleSchedules.length / ITEMS_PER_PAGE));
        document.getElementById('pageInfo').textContent = `Page ${pageNumber} of ${totalPages}`;
        
        const prevBtn = document.getElementById('prevBtn');
        const nextBtn = document.getElementById('nextBtn');
        
        if (prevBtn) prevBtn.disabled = pageNumber === 1;
        if (nextBtn) nextBtn.disabled = pageNumber === totalPages;
      }

      window.displayPage = displayPage;

      displayPage(currentPage);

      window.nextPage = function() {
        const visibleSchedules = allSchedules.filter(item => item.dataset.hidden !== 'true');
        const totalPages = Math.max(1, Math.ceil(visibleSchedules.length / ITEMS_PER_PAGE));
        if (currentPage < totalPages) {
          currentPage++;
          displayPage(currentPage);
        }
      };

      window.previousPage = function() {
        if (currentPage > 1) {
          currentPage--;
          displayPage(currentPage);
        }
      };

      const searchInput = document.getElementById('scheduleSearch');

      function restoreOriginalOrder() {
        originalScheduleOrder.forEach(item => schedulesList.appendChild(item));
        allSchedules = [...originalScheduleOrder];
      }

      function performSearch() {
        const searchTerm = searchInput.value.toLowerCase();
        currentPage = 1;

        if (searchTerm === '') {
          allSchedules.forEach(item => {
            item.dataset.hidden = 'false';
          });
          restoreOriginalOrder();
        } else {
          const matchingItems = [];
          const nonMatchingItems = [];
          
          allSchedules.forEach(item => {
            const text = item.textContent.toLowerCase();
            if (text.includes(searchTerm)) {
              item.dataset.hidden = 'false';
              matchingItems.push(item);
            } else {
              item.dataset.hidden = 'true';
              nonMatchingItems.push(item);
            }
          });
          
          const orderedItems = [...matchingItems, ...nonMatchingItems];
          allSchedules = orderedItems;
          orderedItems.forEach(item => schedulesList.appendChild(item));
        }

        displayPage(currentPage);
      }

      if (searchInput) {
        searchInput.addEventListener('input', performSearch);
      }

    }

    const examDateInput = document.getElementById('examDate');
    const examDateDisplay = document.getElementById('examDateDisplay');
    const examDateModal = document.getElementById('examDateModal');
    const examDateModalClose = document.getElementById('examDateModalClose');
    const prevMonthBtn = document.getElementById('prevMonth');
    const nextMonthBtn = document.getElementById('nextMonth');
    const calendarTitle = document.getElementById('calendarTitle');
    const dateGrid = document.getElementById('dateGrid');
    const scheduleForm = document.querySelector('.schedule-form');
    const holidayWarning = document.getElementById('holidayWarning');
    const capacityWarning = document.getElementById('capacityWarning');
    const holidays = {
      '01-01': "New Year's Day",
      '02-17': 'Chinese New Year',
      '02-25': 'EDSA People Power Revolution Anniversary',
      '03-20': "Eid'l Fitr",
      '04-02': 'Maundy Thursday',
      '04-03': 'Good Friday',
      '04-04': 'Black Saturday',
      '04-09': 'Day of Valor',
      '05-01': 'Labor Day',
      '05-27': "Eid'l Adha",
      '06-12': 'Independence Day',
      '08-21': 'Ninoy Aquino Day',
      '08-31': 'National Heroes Day',
      '11-01': "All Saints' Day",
      '11-02': "All Souls' Day",
      '11-30': 'Bonifacio Day',
      '12-08': 'Feast of the Immaculate Conception of Mary',
      '12-24': 'Christmas Eve',
      '12-25': 'Christmas Day',
      '12-30': 'Rizal Day',
      '12-31': 'Last Day of the Year'
    };

    const allowedMonths = [
      { label: 'March 2026', year: 2026, month: 2 },
      { label: 'April 2026', year: 2026, month: 3 },
      { label: 'May 2026', year: 2026, month: 4 },
      { label: 'June 2026', year: 2026, month: 5 },
      { label: 'July 2026', year: 2026, month: 6 },
      { label: 'August 2026', year: 2026, month: 7 }
    ];

    let activeMonthIndex = 0;

    function pad(value) {
      return String(value).padStart(2, '0');
    }

    function formatHolidayKey(dateValue) {
      const [year, month, day] = dateValue.split('-');
      return `${month}-${day}`;
    }

    function formatDisplayDate(dateValue) {
      const options = { weekday: 'short', month: 'short', day: 'numeric', year: 'numeric' };
      const [year, month, day] = dateValue.split('-').map(Number);
      return new Date(year, month - 1, day).toLocaleDateString('en-US', options);
    }

    function validateHolidayDate(value) {
      if (!value) return true;
      const key = formatHolidayKey(value);
      const name = holidays[key];
      if (name) {
        if (holidayWarning) {
          holidayWarning.textContent = `Cannot schedule on holiday: ${name}`;
        }
        return false;
      }
      if (holidayWarning) {
        holidayWarning.textContent = '';
      }
      return true;
    }

    function isWeekendDate(value) {
      if (!value) return false;
      const [year, month, day] = value.split('-').map(Number);
      const dayOfWeek = new Date(year, month - 1, day).getDay();
      return dayOfWeek === 0 || dayOfWeek === 6;
    }

    function validateWeekendDate(value) {
      if (!value) return true;
      if (!isWeekendDate(value)) {
        if (holidayWarning) {
          holidayWarning.textContent = 'Exam schedules are only available on Saturday and Sunday.';
        }
        return false;
      }
      if (holidayWarning) {
        holidayWarning.textContent = '';
      }
      return true;
    }

    function validateCapacityDate(value) {
      if (!value) {
        if (capacityWarning) {
          capacityWarning.textContent = '';
        }
        return true;
      }
      const count = scheduleCounts[value] || 0;
      if (count >= 50) {
        if (capacityWarning) {
          capacityWarning.textContent = 'This date is fully booked with the maximum of 50 scheduled applicants.';
        }
        return false;
      }
      if (capacityWarning) {
        capacityWarning.textContent = `Current booked applicants for this date: ${count}.`;
      }
      return true;
    }

    function setExamDateInvalid(message) {
      if (holidayWarning) {
        holidayWarning.textContent = message;
      }
      if (examDateDisplay) {
        examDateDisplay.setCustomValidity(message);
      }
    }

    function clearExamDateValidity() {
      if (holidayWarning) {
        holidayWarning.textContent = '';
      }
      if (capacityWarning) {
        capacityWarning.textContent = '';
      }
      if (examDateDisplay) {
        examDateDisplay.setCustomValidity('');
      }
    }

    function getDayCount(year, month) {
      return new Date(year, month + 1, 0).getDate();
    }

    function renderCalendarTitle() {
      if (!calendarTitle) return;
      const { label } = allowedMonths[activeMonthIndex];
      calendarTitle.textContent = label;
      if (prevMonthBtn) {
        prevMonthBtn.disabled = activeMonthIndex === 0;
      }
      if (nextMonthBtn) {
        nextMonthBtn.disabled = activeMonthIndex === allowedMonths.length - 1;
      }
    }

    function isDatePast(dateValue) {
      const [year, month, day] = dateValue.split('-').map(Number);
      const selected = new Date(year, month - 1, day);
      const today = new Date();
      today.setHours(0, 0, 0, 0);
      return selected < today;
    }

    function renderDateGrid() {
      if (!dateGrid) return;
      dateGrid.innerHTML = '';
      const { year, month } = allowedMonths[activeMonthIndex];
      const firstDay = new Date(year, month, 1).getDay();
      const dayCount = getDayCount(year, month);

      for (let i = 0; i < firstDay; i += 1) {
        const emptyCell = document.createElement('div');
        emptyCell.className = 'date-cell empty-cell';
        dateGrid.appendChild(emptyCell);
      }

      for (let day = 1; day <= dayCount; day += 1) {
        const dateValue = `${year}-${pad(month + 1)}-${pad(day)}`;
        const cell = document.createElement('div');
        cell.className = 'date-cell';
        const button = document.createElement('button');
        button.type = 'button';
        button.className = 'date-button';
        button.textContent = day;

        const holiday = holidays[formatHolidayKey(dateValue)];
        const count = scheduleCounts[dateValue] || 0;
        const weekend = isWeekendDate(dateValue);
        const disabled = holiday || !weekend || count >= 50 || isDatePast(dateValue);
        if (disabled) {
          button.disabled = true;
          if (holiday) {
            cell.classList.add('holiday-cell');
            cell.dataset.holiday = holiday;
            button.classList.add('disabled-holiday');
            button.title = `${holiday} - unavailable`;
            button.setAttribute('aria-label', `${day}, ${holiday} - unavailable`);
          } else if (!weekend) {
            button.classList.add('disabled-weekday');
            button.title = 'Weekday - unavailable';
          } else if (count >= 50) {
            button.classList.add('disabled-full');
            button.title = 'Fully booked';
          } else {
            button.title = 'Past date';
          }
        } else {
          button.addEventListener('click', () => {
            selectExamDate(dateValue);
          });
        }

        if (examDateInput && examDateInput.value === dateValue) {
          button.classList.add('active');
        }

        cell.appendChild(button);
        if (holiday) {
          const tooltip = document.createElement('span');
          tooltip.className = 'holiday-tooltip';
          tooltip.textContent = holiday;
          cell.appendChild(tooltip);
        }
        dateGrid.appendChild(cell);
      }

      const totalCells = firstDay + dayCount;
      for (let i = totalCells; i < 42; i += 1) {
        const emptyCell = document.createElement('div');
        emptyCell.className = 'date-cell empty-cell';
        dateGrid.appendChild(emptyCell);
      }
    }

    function selectExamDate(dateValue) {
      if (!examDateInput || !examDateDisplay) return;
      examDateInput.value = dateValue;
      examDateDisplay.value = formatDisplayDate(dateValue);
      validateHolidayDate(dateValue) && validateWeekendDate(dateValue);
      validateCapacityDate(dateValue);
      examDateDisplay.setCustomValidity('');
      renderDateGrid();
      closeExamDateModal();
    }

    function initializeMonthIndex() {
      if (!examDateInput || !examDateInput.value) return;
      const [year, month] = examDateInput.value.split('-');
      const monthNum = parseInt(month, 10);
      const matchingIndex = allowedMonths.findIndex(m => m.year === parseInt(year, 10) && m.month + 1 === monthNum);
      if (matchingIndex !== -1) {
        activeMonthIndex = matchingIndex;
      }
    }

    function openExamDateModal() {
      if (!examDateModal) return;
      initializeMonthIndex();
      renderCalendarTitle();
      renderDateGrid();
      examDateModal.classList.add('active');
      examDateModal.setAttribute('aria-hidden', 'false');
    }

    function closeExamDateModal() {
      if (!examDateModal) return;
      examDateModal.classList.remove('active');
      examDateModal.setAttribute('aria-hidden', 'true');
    }

    examDateDisplay?.addEventListener('click', openExamDateModal);
    examDateModalClose?.addEventListener('click', closeExamDateModal);
    examDateModal?.addEventListener('click', function(event) {
      if (event.target === examDateModal) {
        closeExamDateModal();
      }
    });
    document.addEventListener('keydown', function(event) {
      if (event.key === 'Escape') {
        closeExamDateModal();
      }
    });

    prevMonthBtn?.addEventListener('click', function() {
      if (activeMonthIndex > 0) {
        activeMonthIndex -= 1;
        renderCalendarTitle();
        renderDateGrid();
      }
    });

    nextMonthBtn?.addEventListener('click', function() {
      if (activeMonthIndex < allowedMonths.length - 1) {
        activeMonthIndex += 1;
        renderCalendarTitle();
        renderDateGrid();
      }
    });

    if (dateGrid) {
      renderCalendarTitle();
      renderDateGrid();
    }

    if (examDateInput && examDateInput.value) {
      examDateDisplay.value = formatDisplayDate(examDateInput.value);
    }

    scheduleForm?.addEventListener('submit', function(event) {
      if (selectedStudentInputs && selectedApplicantIds.size === 0) {
        event.preventDefault();
        alert('Please select at least one applicant.');
        studentSearchInput?.focus();
        return;
      }

      if (!examDateInput || !examDateInput.value) {
        setExamDateInvalid('Please select an exam date between March and August 2026.');
        examDateDisplay?.reportValidity();
        event.preventDefault();
        return;
      }

      if (!validateHolidayDate(examDateInput.value) || !validateWeekendDate(examDateInput.value) || !validateCapacityDate(examDateInput.value)) {
        setExamDateInvalid(holidayWarning?.textContent || capacityWarning?.textContent || 'Please choose an available Saturday or Sunday.');
        examDateDisplay?.reportValidity();
        event.preventDefault();
        return;
      }

      const examTimeSelect = document.getElementById('examTime');
      const locationSelect = document.getElementById('location');
      if (!examTimeSelect?.value) {
        event.preventDefault();
        examTimeSelect?.reportValidity();
        return;
      }
      if (!locationSelect?.value) {
        event.preventDefault();
        locationSelect?.reportValidity();
      }
    });
  </script>
</body>
</html>
