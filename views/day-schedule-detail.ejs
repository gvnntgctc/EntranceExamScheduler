<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= day %> Schedule Details</title>
  <link href="https://fonts.googleapis.com/css2?family=Roboto&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body class="admin-page-bg">

  <%- include('partials/sidebar') %>

  <div class="main-content">
    <div class="page-logo">
      <img src="/images/logo.png" alt="PTC Logo" />
    </div>
    <div class="container">
      <button onclick="history.back()" class="btn btn-primary"><i class="fas fa-arrow-left"></i> Back</button>
      <h1>Students Scheduled on <%= day %>, <%= monthName %> <%= year %></h1>

      <div class="search-container" style="margin-bottom:18px;">
        <i class="fas fa-search"></i>
        <input type="search" id="searchInput" placeholder="Search students by name or ID..." oninput="filterStudents()" class="search-input" aria-label="Search students by name or ID" />
      </div>

      <ul id="studentList" class="student-list">
        <% if(schedules.length === 0) { %>
          <li>No students scheduled on this day.</li>
        <% } else { %>
          <% schedules.forEach(({ studentId, examTime, location }) => { %>
            <li class="student-item" data-student-id="<%= studentId ? studentId._id : '' %>">
              <strong><%= studentId ? studentId.fullName : 'Unknown' %></strong>
              <span>ID: <%= studentId ? studentId._id : 'N/A' %></span>
              <span>Time: <%= examTime %></span>
              <span>Location: <%= location %></span>
              <a href="/admin/edit-schedule/<%= studentId._id %>" class="btn-icon edit" title="Edit Schedule">
                <i class="fas fa-edit"></i>
              </a>
            </li>
          <% }) %>
        <% } %>
      </ul>
    </div>
  </div>

  <script>
    function filterStudents() {
      const query = document.getElementById('searchInput').value.toLowerCase();
      const students = document.querySelectorAll('.student-item');
      const studentList = document.getElementById('studentList');
      let visibleCount = 0;

      students.forEach(student => {
        const text = student.textContent.toLowerCase();
        const studentId = student.dataset.studentId ? student.dataset.studentId.toLowerCase() : '';
        const isVisible = text.includes(query) || studentId.includes(query);
        student.style.display = isVisible ? '' : 'none';
        if (isVisible) visibleCount++;
      });

      // Handle empty results message
      let emptyMessage = studentList.querySelector('.empty-message');
      if (visibleCount === 0 && query.trim() !== '') {
        if (!emptyMessage) {
          emptyMessage = document.createElement('li');
          emptyMessage.className = 'empty-message';
          emptyMessage.textContent = 'No applicants found matching your search.';
          studentList.appendChild(emptyMessage);
        }
        emptyMessage.style.display = '';
      } else {
        if (emptyMessage) {
          emptyMessage.style.display = 'none';
        }
      }
    }
  </script>

</body>
</html>