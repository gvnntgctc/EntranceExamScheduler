<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Activity Detail</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="admin-page-bg">
  <%- include('partials/sidebar'); %>
  <div class="sidebar-overlay" id="sidebarOverlay"></div>
  <button class="hamburger" id="hamburger"><i class="fas fa-bars"></i></button>

  <div class="main-content">
    <div class="page-logo">
      <img src="/images/logo.png" alt="PTC Logo" />
    </div>
    <div class="container">
      <a href="/admin/notifications" class="back-link"><i class="fas fa-arrow-left"></i> Back to Activity Log</a>

      <div class="section-card activity-detail-card">
        <div class="activity-header">
          <h1><i class="fas fa-bell"></i> Activity Detail</h1>
          <div class="activity-meta">
            <span class="status-badge status-<%= notification.status %>"><%= notification.status %></span>
            <span class="timestamp" id="sentAtValue" data-timestamp="<%= notification.createdAt.toISOString() %>"></span>
          </div>
        </div>

        <div class="activity-content">
          <div class="activity-section">
            <h2>Recipient Information</h2>
            <div class="detail-grid">
              <div class="detail-item">
                <div class="detail-label">Email Address</div>
                <div class="detail-value"><%= notification.recipientEmail %></div>
              </div>
            </div>
          </div>

          <div class="activity-section">
            <h2>Activity Details</h2>
            <div class="detail-grid">
              <div class="detail-item">
                <div class="detail-label">Action</div>
                <div class="detail-value"><%= notification.actionDescription %></div>
              </div>
              <div class="detail-item">
                <div class="detail-label">Subject</div>
                <div class="detail-value"><%= notification.subject %></div>
              </div>
            </div>
          </div>

          <div class="activity-section">
            <h2>Message Content</h2>
            <div class="message-body">
              <%= notification.body %>
            </div>
          </div>

          <% if (notification.errorMessage) { %>
          <div class="activity-section error-section">
            <h2><i class="fas fa-exclamation-triangle"></i> Error Details</h2>
            <div class="error-message">
              <%= notification.errorMessage %>
            </div>
          </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>

  <script src="/js/script.js"></script>
  <script>
    const sentAtCell = document.getElementById('sentAtValue');
    if (sentAtCell) {
      const timestamp = sentAtCell.getAttribute('data-timestamp');
      if (timestamp) {
        const date = new Date(timestamp);
        if (!Number.isNaN(date.getTime())) {
          const month = (date.getMonth() + 1).toString().padStart(2, '0');
          const day = date.getDate().toString().padStart(2, '0');
          const year = date.getFullYear();
          const hours = date.getHours();
          const minutes = date.getMinutes().toString().padStart(2, '0');
          const ampm = hours >= 12 ? 'PM' : 'AM';
          const displayHours = hours % 12 || 12;
          sentAtCell.textContent = `${month}/${day}/${year} ${displayHours}:${minutes} ${ampm}`;
        }
      }
    }
  </script>
</body>
</html>
