<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Student Dashboard - Exam Scheduler</title>
  <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  
  <!-- Overlay -->
  <div class="sidebar-overlay" id="sidebarOverlay"></div>
  
  <!-- Hamburger Button -->
  <button class="hamburger" id="hamburger"><i class="fas fa-bars"></i></button>
  
  <!-- Sidebar -->
  <div class="sidebar" id="sidebar">
    <button class="sidebar-close" id="sidebarClose"><i class="fas fa-times"></i></button>
    
    <div class="sidebar-header">
      <h2><i class="fas fa-user-graduate"></i> Student Panel</h2>
    </div>
    <ul class="sidebar-menu">
      <li><a href="/student" class="active"><i class="fas fa-calendar-check"></i> My Schedule</a></li>
      
      <li><a href="/auth/logout"><i class="fas fa-sign-out-alt"></i> Logout</a></li>
    </ul>
  </div>
  
  <!-- Main Content -->
  <div class="main-content">
    <div class="page-logo">
      <img src="/images/logo.png" alt="PTC Logo" />
    </div>
    <div class="container">
      <h1><i class="fas fa-tachometer-alt"></i> Welcome, <%= user.fullName %>!</h1>
      <% if (typeof error !== 'undefined' && error) { %><div class="message error"><i class="fas fa-exclamation-circle"></i> <%= error %></div><% } %>
      <% if (typeof success !== 'undefined' && success) { %><div class="message success"><i class="fas fa-check-circle"></i> <%= success %></div><% } %>
      
      <div class="section-card" id="schedule">
        <h2><i class="fas fa-calendar-check"></i> My Exam Schedule</h2>

        <div class="status-card" style="margin-bottom: 20px; padding: 15px; border-radius: 10px; border: 1px solid #e0e0e0; background: #f7faff;">
          <strong>Application Status:</strong>
          <% if (user.status === 'pending') { %>
            <span style="color: #336699;">Pending</span> - <%= user.resultMessage || 'Awaiting schedule confirmation.' %>
          <% } else if (user.status === 'passed') { %>
            <span style="color: #1a8d00;">Passed</span> - <%= user.resultMessage || 'Congratulations! Check your schedule below.' %>
          <% } else if (user.status === 'failed') { %>
            <span style="color: #1a8d00;">Passed (CCS)</span> - <%= user.resultMessage || 'Congratulations! You have qualified for the Certificate in Computer Science (CCS).' %>
          <% } else { %>
            <span style="color: #333;">Unknown</span>
          <% } %>
        </div>

        <% if (!schedule) { %>
          <div class="no-data">
            <i class="fas fa-calendar-times"></i>
            <p>No exam schedule assigned yet.</p>
            <p class="sub-text">Please check back later or contact the admin.</p>
          </div>
        <% } else { %>
          <div class="schedule-card">
            <div class="schedule-card-header">
              <i class="fas fa-calendar-alt"></i>
              <span>Exam Details</span>
            </div>
            <div class="schedule-card-body">
              <div class="schedule-detail">
                <div class="detail-icon">
                  <i class="fas fa-calendar"></i>
                </div>
                <div class="detail-info">
                  <span class="detail-label">Date</span>
                  <span class="detail-value"><%= new Date(schedule.examDate).toDateString() %></span>
                </div>
              </div>
              <div class="schedule-detail">
                <div class="detail-icon">
                  <i class="fas fa-clock"></i>
                </div>
                <div class="detail-info">
                  <span class="detail-label">Time</span>
                  <span class="detail-value"><%= schedule.examTime %></span>
                </div>
              </div>
              <div class="schedule-detail">
                <div class="detail-icon">
                  <i class="fas fa-map-marker-alt"></i>
                </div>
                <div class="detail-info">
                  <span class="detail-label">Location</span>
                  <span class="detail-value"><%= schedule.location %></span>
                </div>
              </div>
            </div>
          </div>
          <div class="form-buttons">
            <a class="btn btn-primary" href="/student/permit"><i class="fas fa-file-pdf"></i> Download Exam Permit</a>
          </div>
        <% } %>
      </div>

      <div class="section-card">
        <h2><i class="fas fa-history"></i> Applicant Timeline</h2>
        <% if (timeline && timeline.length) { %>
          <ul class="schedule-list">
            <% timeline.forEach(item => { %>
              <li><strong><%= item.label %></strong> - <%= new Date(item.date).toLocaleString('en-US') %></li>
            <% }) %>
          </ul>
        <% } else { %>
          <div class="no-data"><p>No timeline events are available yet.</p></div>
        <% } %>
      </div>

      <div class="section-card">
        <h2><i class="fas fa-calendar-plus"></i> Request Reschedule</h2>
        <form action="/student/reschedule-request" method="POST" class="schedule-form">
          <div class="form-group">
            <label for="reason">Reason</label>
            <textarea id="reason" name="reason" maxlength="1000" required aria-label="Reason for reschedule request"></textarea>
          </div>
          <button type="submit" class="btn btn-primary"><i class="fas fa-paper-plane"></i> Submit Request</button>
        </form>
        <% if (rescheduleRequests && rescheduleRequests.length) { %>
          <h3>Previous requests</h3>
          <ul class="schedule-list">
            <% rescheduleRequests.forEach(request => { %>
              <li><strong><%= request.status %></strong> - <%= request.reason %></li>
            <% }) %>
          </ul>
        <% } %>
      </div>
    </div>
  </div>
  
  <script src="/js/script.js"></script>
</body>
</html>
