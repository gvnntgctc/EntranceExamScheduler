<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Apply - Exam Scheduler</title>
  <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  <link rel="stylesheet" href="/css/auth.css">
</head>
<body>
  <div class="container single-panel" id="container">
    <div class="page-logo">
      <img src="/images/logo.png" alt="PTC Logo" />
    </div>
    <div class="form-container sign-in-container" style="max-width: 420px; margin: auto;">
      <form action="/auth/apply-review" method="POST">
        <h1>Applicant Registration</h1>
        <p class="subtitle">Register with your phone number and email for notifications</p>

        <% if (typeof error !== 'undefined' && error.length > 0) { %>
          <div class="message error">
            <i class="fas fa-exclamation-circle"></i> <%= error %>
          </div>
        <% } %>

        <% if (typeof success !== 'undefined' && success.length > 0) { %>
          <div class="message success">
            <i class="fas fa-check-circle"></i> <%= success %>
          </div>
        <% } %>

        <div class="input-group">
          <i class="fas fa-user"></i>
          <input id="fullName" type="text" name="fullName" placeholder="Full Name" value="<%= fullName || '' %>" maxlength="25" required autocomplete="name" pattern="[A-Za-z. ]+" title="Only letters, spaces, and periods are allowed" />
        </div>

        <div class="input-group">
          <i class="fas fa-phone"></i>
          <input id="phoneNumber" type="tel" name="phoneNumber" placeholder="Phone Number" value="<%= phoneNumber || '' %>" maxlength="11" required autocomplete="tel" inputmode="numeric" pattern="[0-9]+" title="Only numbers are allowed" />
        </div>

        <div class="input-group">
          <i class="fas fa-envelope"></i>
          <input id="email" type="email" name="email" placeholder="Your email for notifications" value="<%= email || '' %>" required autocomplete="email" />
        </div>

        <button class="btn-submit" type="submit">
          <i class="fas fa-paper-plane"></i> Register
        </button>
      </form>
      <div style="margin-top: 20px; text-align: center;">
        <p>Have admin access? <a href="/auth/login">Admin login</a></p>
      </div>
    </div>
  </div>
  <script src="/js/disable-once.js"></script>
  <script>
    const fullNameInput = document.getElementById('fullName');
    const phoneInput = document.getElementById('phoneNumber');

    if (fullNameInput) {
      fullNameInput.addEventListener('input', () => {
        fullNameInput.value = fullNameInput.value.replace(/[^A-Za-z. ]+/g, '');
        if (fullNameInput.value.length > 25) {
          fullNameInput.value = fullNameInput.value.slice(0, 25);
        }
      });
    }

    if (phoneInput) {
      phoneInput.addEventListener('input', () => {
        phoneInput.value = phoneInput.value.replace(/[^0-9]+/g, '');
        if (phoneInput.value.length > 11) {
          phoneInput.value = phoneInput.value.slice(0, 11);
        }
      });
    }

    document.querySelector('form').addEventListener('submit', function(e) {
      const fullName = fullNameInput ? fullNameInput.value.trim() : '';
      const phoneNumber = phoneInput ? phoneInput.value.trim() : '';
      const email = document.getElementById('email') ? document.getElementById('email').value.trim() : '';

      const nameIsValid = /^[A-Za-z. ]+$/.test(fullName);
      const phoneIsValid = /^[0-9]+$/.test(phoneNumber);

      if (!nameIsValid || !phoneIsValid || fullName.length > 25 || phoneNumber.length > 11) {
        e.preventDefault();
        alert('Please enter a valid name using only letters, spaces, and periods (max 25 chars) and a phone number using only digits (max 11 chars).');
        return;
      }

      console.log('Submitting registration data:', { fullName, phoneNumber, email });
    });
  </script>
</body>
</html>
