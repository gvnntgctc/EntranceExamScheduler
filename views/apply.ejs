<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Apply - Exam Scheduler</title>
  <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  <link rel="stylesheet" href="/css/auth.css">
</head>
<body>
  <div class="container single-panel" id="container">
    <div class="form-container sign-in-container" style="max-width: 420px; margin: auto;">
      <form action="/auth/apply-review" method="POST">
        <h1>Applicant Registration</h1>
        <p class="subtitle">Register with your phone number and email for notifications</p>

        <% if (typeof error !== 'undefined' && error.length > 0) { %>
          <div class="message error">
            <i class="fas fa-exclamation-circle"></i> <%= error %>
          </div>
        <% } %>

        <% if (typeof success !== 'undefined' && success.length > 0) { %>
          <div class="message success">
            <i class="fas fa-check-circle"></i> <%= success %>
          </div>
        <% } %>

        <div class="input-group">
          <i class="fas fa-user"></i>
          <input type="text" name="fullName" placeholder="Full Name" value="<%= fullName || '' %>" required autocomplete="name" />
        </div>

        <div class="input-group">
          <i class="fas fa-phone"></i>
          <input type="tel" name="phoneNumber" placeholder="Phone Number" value="<%= phoneNumber || '' %>" required autocomplete="tel" />
        </div>

        <div class="input-group">
          <i class="fas fa-envelope"></i>
          <input type="email" name="email" placeholder="Your email for notifications" value="<%= email || '' %>" required autocomplete="email" />
        </div>

        <button class="btn-submit" type="submit">
          <i class="fas fa-paper-plane"></i> Continue to Review
        </button>
      </form>
      <div style="margin-top: 20px; text-align: center;">
        <p>Have admin access? <a href="/auth/login">Admin login</a></p>
      </div>
    </div>
  </div>
  <script src="/js/disable-once.js"></script>
</body>
</html>
