<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Schedule Availability</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .availability-page .availability-top {
      display: grid;
      grid-template-columns: repeat(4, minmax(150px, 1fr));
      gap: 12px;
      margin: 18px 0;
    }
    .availability-page .metric-card {
      padding: 16px;
      border-radius: 8px;
      background: rgba(255, 255, 255, 0.78);
      border: 1px solid rgba(226, 232, 240, 0.85);
    }
    .availability-page .metric-card span {
      display: block;
      color: #64748b;
      font-size: 12px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.4px;
    }
    .availability-page .metric-card strong {
      display: block;
      margin-top: 5px;
      color: #1f2937;
      font-size: 26px;
      line-height: 1.1;
    }
    .availability-toolbar {
      position: sticky;
      top: 0;
      z-index: 5;
      display: grid;
      grid-template-columns: minmax(220px, 1fr) minmax(150px, 0.5fr) minmax(150px, 0.5fr) auto;
      gap: 10px;
      align-items: center;
      padding: 14px;
      margin-bottom: 14px;
      border-radius: 8px;
      background: rgba(248, 250, 252, 0.94);
      border: 1px solid rgba(226, 232, 240, 0.9);
      backdrop-filter: blur(12px);
    }
    .availability-toolbar input,
    .availability-toolbar select {
      width: 100%;
      min-height: 44px;
      border: 1px solid #d9dee5;
      border-radius: 8px;
      padding: 10px 12px;
      background: #fff;
      color: var(--color-text);
    }
    .availability-toolbar .btn {
      min-height: 44px;
      white-space: nowrap;
    }
    .availability-list {
      display: grid;
      gap: 14px;
    }
    .availability-month {
      padding: 0;
      overflow: hidden;
      border-radius: 8px;
    }
    .availability-month[hidden],
    .availability-day[hidden] {
      display: none;
    }
    .month-summary {
      display: grid;
      grid-template-columns: minmax(200px, 1fr) repeat(4, minmax(88px, auto)) 24px;
      gap: 12px;
      align-items: center;
      padding: 18px;
      cursor: pointer;
      list-style: none;
    }
    .month-summary::-webkit-details-marker {
      display: none;
    }
    .month-body {
      display: grid;
      gap: 8px;
      padding: 0 14px 14px;
    }
    .availability-day {
      margin-bottom: 0;
      padding: 0;
      overflow: hidden;
      border-radius: 8px;
      background: rgba(255, 255, 255, 0.72);
      border: 1px solid rgba(226, 232, 240, 0.76);
    }
    .availability-summary {
      display: grid;
      grid-template-columns: minmax(180px, 1fr) repeat(4, minmax(82px, auto)) 20px;
      gap: 12px;
      align-items: center;
      padding: 12px 14px;
      cursor: pointer;
      list-style: none;
    }
    .availability-summary::-webkit-details-marker {
      display: none;
    }
    .month-date strong,
    .availability-date strong,
    .availability-count strong {
      display: block;
      color: #1f2937;
      line-height: 1.2;
    }
    .month-date span,
    .availability-date span,
    .availability-count span {
      display: block;
      margin-top: 3px;
      color: #64748b;
      font-size: 12px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.35px;
    }
    .availability-progress {
      grid-column: 1 / -1;
      height: 7px;
      overflow: hidden;
      border-radius: 999px;
      background: #e2e8f0;
    }
    .availability-progress span {
      display: block;
      height: 100%;
      width: var(--used, 0%);
      background: #167a3a;
      border-radius: inherit;
    }
    .availability-chevron {
      color: #64748b;
      transition: transform 0.2s ease;
    }
    .availability-month[open] > .month-summary .availability-chevron,
    .availability-day[open] > .availability-summary .availability-chevron {
      transform: rotate(180deg);
    }
    .availability-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
      gap: 10px;
      padding: 0 18px 18px;
    }
    .slot-card {
      border: 1px solid #dbe7df;
      border-radius: 8px;
      padding: 12px;
      background: #f8fcf9;
    }
    .slot-card.full { background: #fff1f2; border-color: #fecdd3; }
    .slot-card.blocked { background: #fff7ed; border-color: #fed7aa; }
    .slot-card strong {
      display: block;
      color: #1f2937;
      margin-bottom: 6px;
    }
    .slot-meta {
      display: grid;
      gap: 3px;
      color: #435348;
      font-size: 13px;
    }
    .slot-status {
      display: inline-flex;
      align-items: center;
      width: fit-content;
      margin-top: 8px;
      padding: 5px 9px;
      border-radius: 999px;
      font-size: 12px;
      font-weight: 700;
    }
    .slot-status.open { background: #dcfce7; color: #166534; }
    .slot-status.full { background: #fee2e2; color: #991b1b; }
    .slot-status.blocked { background: #ffedd5; color: #9a3412; }
    .availability-empty {
      display: none;
      text-align: center;
      color: #64748b;
    }
    .availability-empty.is-visible {
      display: block;
    }
    @media (max-width: 900px) {
      .availability-page .availability-top,
      .availability-toolbar,
      .month-summary,
      .availability-summary {
        grid-template-columns: 1fr 1fr;
      }
      .availability-toolbar input,
      .availability-toolbar .btn {
        grid-column: 1 / -1;
      }
      .availability-chevron {
        display: none;
      }
    }
    @media (max-width: 560px) {
      .availability-page .availability-top,
      .availability-toolbar,
      .month-summary,
      .availability-summary {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>
<body class="admin-page-bg availability-page">
  <%- include('partials/sidebar', { page: 'availability' }) %>
  <div class="sidebar-overlay" id="sidebarOverlay"></div>
  <button class="hamburger" id="hamburger" aria-label="Open menu"><i class="fas fa-bars"></i></button>

  <div class="main-content">
    <div class="page-logo"><img src="/images/logo.png" alt="PTC Logo" /></div>
    <div class="container">
      <h1><i class="fas fa-table"></i> Slot Availability</h1>
      <p class="sub-text">Admission cycle: <%= scheduleConfig.cycleLabel %></p>
      <div class="form-buttons">
        <a class="btn btn-primary" href="/admin/add-schedule"><i class="fas fa-calendar-plus"></i> Add Schedule</a>
        <a class="btn btn-secondary" href="/admin/settings"><i class="fas fa-sliders-h"></i> Settings</a>
      </div>

      <%
        const totalDays = days.length;
        const blockedDays = days.filter(day => day.holidayName).length;
        const totalSlots = days.reduce((sum, day) => sum + day.slots.length, 0);
        const totalRemaining = days.reduce((sum, day) => sum + (day.holidayName ? 0 : day.slots.reduce((slotSum, slot) => slotSum + slot.remaining, 0)), 0);
        const fullSlots = days.reduce((sum, day) => sum + (day.holidayName ? day.slots.length : day.slots.filter(slot => slot.remaining <= 0).length), 0);
        const openSlots = Math.max(0, totalSlots - fullSlots);
        const monthOptions = [...new Set(days.map(day => {
          const date = new Date(`${day.dateKey}T00:00:00`);
          return `${date.getFullYear()}-${String(date.getMonth() + 1).padStart(2, '0')}|${date.toLocaleDateString('en-US', { month: 'long', year: 'numeric' })}`;
        }))];
        const decorateDay = (day) => {
          const isBlockedDay = !!day.holidayName;
          const booked = day.slots.reduce((sum, slot) => sum + slot.bookedCount, 0);
          const capacity = day.slots.reduce((sum, slot) => sum + slot.maxCapacity, 0);
          const remaining = isBlockedDay ? 0 : day.slots.reduce((sum, slot) => sum + slot.remaining, 0);
          const fullSlotsForDay = isBlockedDay ? day.slots.length : day.slots.filter(slot => slot.remaining <= 0).length;
          const openSlotsForDay = isBlockedDay ? 0 : day.slots.length - fullSlotsForDay;
          const dateObject = new Date(`${day.dateKey}T00:00:00`);
          const monthKey = `${dateObject.getFullYear()}-${String(dateObject.getMonth() + 1).padStart(2, '0')}`;
          return {
            ...day,
            booked,
            capacity,
            remaining,
            openSlots: openSlotsForDay,
            usedPercent: capacity > 0 ? Math.min(100, Math.round((booked / capacity) * 100)) : 0,
            monthKey,
            status: isBlockedDay ? 'blocked' : (openSlotsForDay > 0 ? 'open' : 'full'),
            search: `${day.displayDate} ${day.holidayName || ''} ${day.slots.map(slot => `${slot.room} ${slot.timeSlot}`).join(' ')}`.toLowerCase()
          };
        };
        const decoratedDays = days.map(decorateDay);
        const monthGroups = monthOptions.map(option => {
          const [monthKey, label] = option.split('|');
          const monthDays = decoratedDays.filter(day => day.monthKey === monthKey);
          const monthBooked = monthDays.reduce((sum, day) => sum + day.booked, 0);
          const monthCapacity = monthDays.reduce((sum, day) => sum + day.capacity, 0);
          const monthRemaining = monthDays.reduce((sum, day) => sum + day.remaining, 0);
          const monthOpenSlots = monthDays.reduce((sum, day) => sum + day.openSlots, 0);
          const monthBlockedDays = monthDays.filter(day => day.holidayName).length;
          return {
            monthKey,
            label,
            days: monthDays,
            booked: monthBooked,
            capacity: monthCapacity,
            remaining: monthRemaining,
            openSlots: monthOpenSlots,
            blockedDays: monthBlockedDays,
            usedPercent: monthCapacity > 0 ? Math.min(100, Math.round((monthBooked / monthCapacity) * 100)) : 0
          };
        });
      %>

      <div class="availability-top">
        <div class="metric-card"><span>Schedule Days</span><strong><%= totalDays %></strong></div>
        <div class="metric-card"><span>Available Seats</span><strong><%= totalRemaining %></strong></div>
        <div class="metric-card"><span>Open Slots</span><strong><%= openSlots %></strong></div>
        <div class="metric-card"><span>Blocked Days</span><strong><%= blockedDays %></strong></div>
      </div>

      <% if (!days.length) { %>
        <div class="section-card no-data">
          <i class="fas fa-calendar-times"></i>
          <p>No available schedule days are inside the current admission cycle.</p>
          <a class="btn btn-primary" href="/admin/settings">Review Settings</a>
        </div>
      <% } %>

      <% if (days.length) { %>
        <div class="availability-toolbar" aria-label="Availability filters">
          <input id="availabilitySearch" type="search" placeholder="Search date, room, or time..." aria-label="Search availability">
          <select id="availabilityMonth" aria-label="Filter by month">
            <option value="all">All months</option>
            <% monthOptions.forEach(option => {
              const [value, label] = option.split('|');
            %>
              <option value="<%= value %>"><%= label %></option>
            <% }) %>
          </select>
          <select id="availabilityStatus" aria-label="Filter by status">
            <option value="all">All statuses</option>
            <option value="open">Available</option>
            <option value="full">Full</option>
            <option value="blocked">Blocked</option>
          </select>
          <button class="btn btn-secondary" type="button" id="toggleAvailability"><i class="fas fa-chevron-down"></i> Expand Months</button>
        </div>
      <% } %>

      <div class="availability-list" id="availabilityList">
      <% monthGroups.forEach((month, monthIndex) => { %>
        <details class="section-card availability-month" data-month="<%= month.monthKey %>" <%= monthIndex === 0 ? 'open' : '' %>>
          <summary class="month-summary">
            <div class="month-date">
              <strong><i class="fas fa-calendar-alt"></i> <%= month.label %></strong>
              <span><%= month.days.length %> schedule day<%= month.days.length === 1 ? '' : 's' %></span>
            </div>
            <div class="availability-count"><strong><%= month.remaining %></strong><span>Seats Left</span></div>
            <div class="availability-count"><strong><%= month.openSlots %></strong><span>Open Slots</span></div>
            <div class="availability-count"><strong><%= month.booked %></strong><span>Booked</span></div>
            <div class="availability-count"><strong><%= month.blockedDays %></strong><span>Blocked</span></div>
            <i class="fas fa-chevron-down availability-chevron"></i>
            <div class="availability-progress" style="--used:<%= month.usedPercent %>%"><span></span></div>
          </summary>
          <div class="month-body">
            <% month.days.forEach(day => { %>
              <details class="availability-day" data-month="<%= day.monthKey %>" data-status="<%= day.status %>" data-search="<%= day.search %>">
                <summary class="availability-summary">
                  <div class="availability-date">
                    <strong><i class="fas fa-calendar-day"></i> <%= day.displayDate %></strong>
                    <span><%= day.holidayName ? day.holidayName : `${day.openSlots} available slot${day.openSlots === 1 ? '' : 's'}` %></span>
                  </div>
                  <div class="availability-count"><strong><%= day.remaining %></strong><span>Seats Left</span></div>
                  <div class="availability-count"><strong><%= day.booked %></strong><span>Booked</span></div>
                  <div class="availability-count"><strong><%= day.capacity %></strong><span>Capacity</span></div>
                  <% if (day.holidayName) { %>
                    <span class="slot-status blocked"><i class="fas fa-ban"></i>&nbsp; Blocked</span>
                  <% } else if (day.openSlots > 0) { %>
                    <span class="slot-status open"><%= day.openSlots %> Open</span>
                  <% } else { %>
                    <span class="slot-status full">Full</span>
                  <% } %>
                  <i class="fas fa-chevron-down availability-chevron"></i>
                  <div class="availability-progress" style="--used:<%= day.usedPercent %>%"><span></span></div>
                </summary>
                <div class="availability-grid">
                  <% day.slots.forEach(slot => {
                    const isBlocked = !!day.holidayName;
                    const isFull = !isBlocked && slot.remaining <= 0;
                  %>
                    <div class="slot-card <%= isBlocked ? 'blocked' : (isFull ? 'full' : '') %>">
                      <strong><%= slot.room %></strong>
                      <div class="slot-meta">
                        <span><i class="fas fa-clock"></i> <%= slot.timeSlot %></span>
                        <span>Booked: <%= slot.bookedCount %></span>
                        <span>Capacity: <%= slot.maxCapacity %></span>
                        <span>Remaining: <%= isBlocked ? 0 : slot.remaining %></span>
                      </div>
                      <span class="slot-status <%= isBlocked ? 'blocked' : (isFull ? 'full' : 'open') %>">
                        <%= isBlocked ? 'Blocked' : (isFull ? 'Full' : 'Available') %>
                      </span>
                    </div>
                  <% }) %>
                </div>
              </details>
            <% }) %>
          </div>
        </details>
      <% }) %>
      </div>
      <div class="section-card availability-empty" id="availabilityEmpty">
        No days match the selected filters.
      </div>
    </div>
  </div>
  <script src="/js/script.js"></script>
  <script>
    const searchInput = document.getElementById('availabilitySearch');
    const monthFilter = document.getElementById('availabilityMonth');
    const statusFilter = document.getElementById('availabilityStatus');
    const toggleButton = document.getElementById('toggleAvailability');
    const emptyState = document.getElementById('availabilityEmpty');
    const monthCards = Array.from(document.querySelectorAll('.availability-month'));
    const dayCards = Array.from(document.querySelectorAll('.availability-day'));

    function applyAvailabilityFilters() {
      const searchTerm = (searchInput?.value || '').trim().toLowerCase();
      const monthValue = monthFilter?.value || 'all';
      const statusValue = statusFilter?.value || 'all';
      let visibleCount = 0;

      monthCards.forEach(monthCard => {
        let visibleDaysInMonth = 0;

        monthCard.querySelectorAll('.availability-day').forEach(card => {
          const matchesSearch = !searchTerm || card.dataset.search.includes(searchTerm);
          const matchesMonth = monthValue === 'all' || card.dataset.month === monthValue;
          const matchesStatus = statusValue === 'all' || card.dataset.status === statusValue;
          const isVisible = matchesSearch && matchesMonth && matchesStatus;

          card.hidden = !isVisible;
          if (isVisible) {
            visibleDaysInMonth += 1;
            visibleCount += 1;
          }
        });

        monthCard.hidden = visibleDaysInMonth === 0;
        if (visibleDaysInMonth > 0 && (searchTerm || statusValue !== 'all' || monthValue !== 'all')) {
          monthCard.open = true;
        }
      });

      if (emptyState) {
        emptyState.classList.toggle('is-visible', visibleCount === 0 && dayCards.length > 0);
      }
    }

    function updateToggleLabel() {
      if (!toggleButton) return;
      const visibleCards = monthCards.filter(card => !card.hidden);
      const allOpen = visibleCards.length > 0 && visibleCards.every(card => card.open);
      toggleButton.innerHTML = `<i class="fas fa-chevron-${allOpen ? 'up' : 'down'}"></i> ${allOpen ? 'Collapse Months' : 'Expand Months'}`;
    }

    [searchInput, monthFilter, statusFilter].forEach(control => {
      control?.addEventListener('input', () => {
        applyAvailabilityFilters();
        updateToggleLabel();
      });
    });

    toggleButton?.addEventListener('click', () => {
      const visibleCards = monthCards.filter(card => !card.hidden);
      const shouldOpen = visibleCards.some(card => !card.open);
      visibleCards.forEach(card => {
        card.open = shouldOpen;
      });
      updateToggleLabel();
    });

    monthCards.forEach(card => card.addEventListener('toggle', updateToggleLabel));
    dayCards.forEach(card => card.addEventListener('toggle', updateToggleLabel));
    applyAvailabilityFilters();
    updateToggleLabel();
  </script>
</body>
</html>
