<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= monthName %> - Calendar View</title>
  <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
  <style>
    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 20px;
    }

    .page-header {
      margin-bottom: 30px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .header-content h1 {
      font-weight: 700;
      font-size: 32px;
      margin: 0;
      color: #222;
    }

    .header-content p {
      font-size: 14px;
      color: #666;
      margin: 8px 0 0 0;
    }

    .back-button {
      background: linear-gradient(135deg, #1B5E20 0%, #2E7D32 100%);
      color: white;
      border: none;
      padding: 12px 24px;
      border-radius: 8px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s ease;
      font-size: 14px;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 8px;
    }

    .back-button:hover {
      box-shadow: 0 8px 16px rgba(27, 94, 32, 0.3);
      transform: translateY(-2px);
    }

    .calendar-container {
      background: white;
      border-radius: 16px;
      box-shadow: 0 4px 15px rgb(0 0 0 / 8%);
      overflow: hidden;
    }

    .calendar-header {
      background: linear-gradient(135deg, #1B5E20 0%, #2E7D32 100%);
      color: white;
      padding: 24px;
      text-align: center;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
    }

    .calendar-header h2 {
      margin: 0;
      font-size: 24px;
      color: white;
    }

    .calendar-header p {
      display: none;
    }

    .month-nav-btn {
      background: rgba(255, 255, 255, 0.2);
      color: white;
      border: none;
      width: 40px;
      height: 40px;
      border-radius: 8px;
      font-size: 20px;
      cursor: pointer;
      transition: all 0.3s ease;
      display: flex;
      align-items: center;
      justify-content: center;
      position: absolute;
    }

    .month-nav-btn:hover {
      background: rgba(255, 255, 255, 0.3);
      transform: scale(1.1);
    }

    .month-nav-btn:disabled {
      opacity: 0.5;
      cursor: not-allowed;
      transform: scale(1);
    }

    .month-nav-btn#prevMonthBtn {
      left: 24px;
    }

    .month-nav-btn#nextMonthBtn {
      right: 24px;
    }

    .weekday-headers {
      display: grid;
      grid-template-columns: repeat(7, 1fr);
      gap: 1px;
      background: #e0e0e0;
      padding: 1px;
    }

    .weekday-header {
      background: #f5f5f5;
      padding: 12px;
      text-align: center;
      font-weight: 700;
      font-size: 13px;
      color: #555;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .calendar-grid {
      display: grid;
      grid-template-columns: repeat(7, 1fr);
      gap: 1px;
      background: #e0e0e0;
      padding: 1px;
    }

    .calendar-day {
      background: white;
      min-height: 120px;
      padding: 10px;
      position: relative;
      font-size: 12px;
    }

    .calendar-day.other-month {
      background: #fafafa;
      color: #999;
    }

    .calendar-day.today {
      background: linear-gradient(135deg, rgba(27, 94, 32, 0.1) 0%, rgba(46, 125, 50, 0.1) 100%);
      border: 2px solid #1B5E20;
    }

    .calendar-day.holiday-day {
      background: #fff7ed;
      border: 1px solid #fed7aa;
    }

    .calendar-day.today.holiday-day {
      border: 2px solid #1B5E20;
      box-shadow: inset 0 0 0 1px #fed7aa;
    }

    .day-number {
      font-weight: 700;
      color: #333;
      margin-bottom: 8px;
      display: block;
    }

    .calendar-day.other-month .day-number {
      color: #bbb;
    }

    .scheduled-list {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .scheduled-applicant {
      background: linear-gradient(135deg, rgba(27, 94, 32, 0.9) 0%, rgba(46, 125, 50, 0.9) 100%);
      color: white;
      padding: 4px 6px;
      border-radius: 4px;
      font-size: 11px;
      font-weight: 600;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      transition: all 0.2s ease;
    }

    .applicant-count {
      background: linear-gradient(135deg, #1B5E20 0%, #2E7D32 100%);
      color: white;
      padding: 8px 12px;
      border-radius: 6px;
      font-size: 13px;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.2s ease;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      border: none;
      user-select: none;
    }

    .applicant-count:hover {
      transform: scale(1.1);
      box-shadow: 0 4px 12px rgba(27, 94, 32, 0.3);
    }

    .calendar-day .no-schedule {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 52px;
      margin-top: 10px;
      padding: 0;
      background: transparent;
      border-radius: 0;
      box-shadow: none;
      text-align: center;
      color: #bbb;
      font-size: 11px;
      font-style: italic;
    }

    .holiday-label {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      max-width: 100%;
      margin: 4px 0 8px;
      padding: 5px 7px;
      border: 1px solid #fdba74;
      border-radius: 999px;
      background: #ffedd5;
      color: #9a3412;
      font-size: 11px;
      font-weight: 700;
      line-height: 1.2;
      cursor: help;
    }

    .holiday-label span {
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .holiday-label i {
      flex: 0 0 auto;
      font-size: 10px;
    }

    .modal-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(15, 23, 42, 0.58);
      backdrop-filter: blur(4px);
      z-index: 999;
      animation: fadeIn 0.2s ease;
      padding: 24px;
    }

    .modal-overlay.active {
      display: flex;
      align-items: center;
      justify-content: center;
    }

    @keyframes fadeIn {
      from { opacity: 0; }
      to { opacity: 1; }
    }

    .modal-content {
      background: #ffffff;
      border-radius: 18px;
      box-shadow: 0 28px 80px rgba(15, 23, 42, 0.32);
      border: 1px solid rgba(255, 255, 255, 0.7);
      max-width: 580px;
      width: min(580px, 100%);
      max-height: 82vh;
      min-height: 520px;
      overflow: hidden;
      display: flex;
      flex-direction: column;
      animation: slideUp 0.3s ease;
    }

    @keyframes slideUp {
      from {
        transform: translateY(20px);
        opacity: 0;
      }
      to {
        transform: translateY(0);
        opacity: 1;
      }
    }

    .modal-header {
      background: linear-gradient(135deg, #155f24 0%, #1f7a34 100%);
      color: white;
      padding: 18px 20px 20px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex: 0 0 auto;
      gap: 16px;
    }

    .modal-header h3 {
      margin: 0;
      font-size: 19px;
      font-weight: 700;
      line-height: 1.25;
      color: white;
    }

    .modal-header-title {
      min-width: 0;
    }

    .modal-kicker {
      display: block;
      margin-bottom: 5px;
      color: rgba(255, 255, 255, 0.78);
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .modal-title-row {
      display: flex;
      align-items: center;
      gap: 10px;
      flex-wrap: wrap;
    }

    .applicant-count-pill {
      flex: 0 0 auto;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 10px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.13);
      border: 1px solid rgba(255, 255, 255, 0.26);
      color: white;
      font-size: 12px;
      font-weight: 700;
    }

    .modal-close-btn {
      background: rgba(255, 255, 255, 0.12);
      border: 1px solid rgba(255, 255, 255, 0.18);
      color: white;
      font-size: 16px;
      cursor: pointer;
      width: 42px;
      height: 42px;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.2s ease;
    }

    .modal-close-btn:hover {
      background: rgba(255, 255, 255, 0.2);
      transform: translateY(-1px);
    }

    .modal-body {
      padding: 22px 24px 24px;
      display: flex;
      flex-direction: column;
      gap: 16px;
      flex: 1 1 auto;
      min-height: 0;
      overflow: hidden;
      background: linear-gradient(180deg, #f8fbf9 0%, #ffffff 42%);
    }

    .export-status {
      padding: 12px 16px;
      border-radius: 12px;
      font-size: 14px;
      line-height: 1.4;
      border: 1px solid transparent;
      min-height: 42px;
    }

    .export-status.success {
      background: #ecf9f3;
      color: #1f7a4b;
      border-color: #b7f0c8;
    }

    .export-status.error {
      background: #fff1f0;
      color: #a33d2b;
      border-color: #f5c6c3;
    }

    .export-status.hidden {
      display: none;
    }

    .export-btn {
      background: rgba(255, 255, 255, 0.94);
      color: white;
      border: 1px solid rgba(255, 255, 255, 0.5);
      padding: 0 15px;
      border-radius: 12px;
      min-height: 42px;
      font-size: 13px;
      cursor: pointer;
      transition: transform 0.2s ease, opacity 0.2s ease, filter 0.2s ease;
      white-space: nowrap;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-weight: 700;
      color: #166427;
      box-shadow: 0 10px 22px rgba(4, 44, 15, 0.16);
    }

    .export-btn:hover:not(:disabled) {
      filter: brightness(1.02);
      transform: translateY(-1px);
    }

    .export-btn:disabled {
      opacity: 0.65;
      cursor: not-allowed;
    }

    #modalBody {
      flex: 1 1 auto;
      min-height: 0;
      overflow-y: auto;
      display: flex;
      flex-direction: column;
      gap: 10px;
      padding: 2px 4px 4px 0;
    }

    .modal-search {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 0 14px;
      min-height: 56px;
      border-radius: 16px;
      margin-bottom: 0;
      flex: 0 0 auto;
      background: #ffffff;
      border: 1px solid #dce8e2;
      box-shadow: 0 12px 28px rgba(15,23,42,0.06);
    }

    .modal-search i {
      width: 34px;
      height: 34px;
      border-radius: 10px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      color: #138a7a;
      background: #edf8f5;
      font-size: 15px;
      margin-left: 0;
    }

    .modal-search .search-input {
      border: none;
      background: transparent;
      outline: none;
      width: 100%;
      height: 54px;
      font-size: 14px;
      color: #26352a;
      padding: 0;
      transition: box-shadow 0.16s ease, border-color 0.16s ease;
      -webkit-appearance: none;
      appearance: none;
    }

    .modal-search .search-input::placeholder {
      color: #8a9b93;
      font-weight: 600;
    }

    .modal-search .search-input:focus {
      box-shadow: none;
    }

    .modal-filters {
      display: inline-flex;
      align-self: flex-start;
      flex-wrap: wrap;
      gap: 4px;
      margin: 0 0 4px;
      padding: 4px;
      border-radius: 13px;
      background: #f2f7f3;
      border: 1px solid #dce8df;
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.8);
    }

    .filter-btn {
      background: transparent;
      border: none;
      color: #3d5942;
      min-width: 48px;
      padding: 9px 14px;
      border-radius: 9px;
      cursor: pointer;
      font-weight: 700;
      font-size: 13px;
      transition: all 0.2s ease;
    }

    .filter-btn:hover,
    .filter-btn.active {
      background: #1b6f28;
      color: white;
      box-shadow: 0 8px 18px rgba(27, 111, 40, 0.18);
    }

    .applicant-item {
      padding: 13px 14px;
      background: #ffffff;
      border: 1px solid #e4eee7;
      border-left: 5px solid #1B5E20;
      border-radius: 12px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 14px;
      box-shadow: 0 8px 22px rgba(15, 23, 42, 0.05);
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .applicant-item:hover {
      transform: translateY(-1px);
      box-shadow: 0 14px 30px rgba(15, 23, 42, 0.08);
    }

    .applicant-main {
      display: flex;
      align-items: center;
      min-width: 0;
      gap: 12px;
    }

    .applicant-avatar {
      flex: 0 0 auto;
      width: 36px;
      height: 36px;
      border-radius: 50%;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: #eaf7ef;
      color: #1B5E20;
      border: 1px solid #d2ead9;
    }

    .applicant-name {
      font-size: 15px;
      font-weight: 700;
      color: #26352a;
      overflow-wrap: anywhere;
    }

    .applicant-time {
      background: #f8faf8;
      padding: 8px 11px;
      border-radius: 999px;
      font-size: 12px;
      color: #51605a;
      border: 1px solid #dfe8e2;
      white-space: nowrap;
      font-weight: 700;
      display: inline-flex;
      align-items: center;
      gap: 5px;
    }

    .empty-applicants {
      text-align: center;
      padding: 44px 20px;
      color: #7a8a83;
      background: #ffffff;
      border: 1px dashed #d8e5dc;
      border-radius: 14px;
    }

    .empty-applicants i {
      font-size: 40px;
      color: #b7c7bd;
      margin-bottom: 12px;
      display: block;
    }

    #applicantModal .modal-content {
      max-width: 580px;
      width: min(580px, 100%);
      max-height: 82vh;
      min-height: 520px;
      border-radius: 18px;
    }

    #applicantModal .modal-header {
      padding: 18px 20px;
      min-height: auto;
      gap: 16px;
      background: linear-gradient(135deg, #155f24 0%, #1f7a34 100%);
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      flex-wrap: nowrap;
      font-size: initial;
    }

    #applicantModal .modal-header-title {
      display: block;
      flex: 1 1 auto;
      min-width: 0;
      margin: 0;
      line-height: 1.2;
      font-size: initial;
    }

    #applicantModal .modal-header-actions {
      display: flex;
      align-items: center;
      justify-content: flex-end;
      gap: 8px;
      flex: 0 0 auto;
      padding: 4px;
      border-radius: 16px;
      background: rgba(255, 255, 255, 0.08);
      border: 1px solid rgba(255, 255, 255, 0.14);
    }

    #applicantModal .modal-header-actions .btn {
      width: auto !important;
      min-width: 0;
      padding: 0 15px;
      border-radius: 12px;
    }

    #applicantModal .modal-close-btn {
      width: 42px;
      height: 42px;
      border-radius: 12px;
    }

    .schedule-details {
      margin-top: 30px;
      background: white;
      border-radius: 16px;
      box-shadow: 0 4px 15px rgb(0 0 0 / 8%);
      overflow: hidden;
    }

    .schedule-details-header {
      background: #f5f5f5;
      padding: 20px 24px;
      border-bottom: 1px solid #e0e0e0;
    }

    .schedule-details-header h3 {
      margin: 0;
      font-size: 18px;
      color: #333;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .schedule-list {
      padding: 20px 24px;
    }

    .schedule-item {
      padding: 16px;
      margin-bottom: 12px;
      background: #f9f9f9;
      border-left: 4px solid #1B5E20;
      border-radius: 6px;
      display: flex;
      justify-content: space-between;
      align-items: start;
    }

    .schedule-item-content {
      flex-grow: 1;
    }

    .schedule-item-date {
      font-weight: 700;
      color: #1B5E20;
      font-size: 14px;
    }

    .schedule-item-applicant {
      font-size: 16px;
      color: #333;
      margin-top: 6px;
      font-weight: 600;
    }

    .schedule-item-time {
      background: white;
      padding: 6px 12px;
      border-radius: 6px;
      font-size: 13px;
      color: #666;
      white-space: nowrap;
      border: 1px solid #e0e0e0;
    }

    .empty-message {
      text-align: center;
      padding: 40px 20px;
      color: #999;
    }

    .empty-message i {
      font-size: 48px;
      color: #ddd;
      margin-bottom: 16px;
      display: block;
    }

    .empty-message p {
      font-size: 16px;
      margin: 0;
    }

    @media(max-width: 768px) {
      .page-header {
        flex-direction: column;
        align-items: flex-start;
        gap: 16px;
      }

      .calendar-day {
        min-height: 100px;
        font-size: 11px;
      }

      .day-number {
        margin-bottom: 4px;
      }

      .scheduled-applicant {
        font-size: 10px;
        padding: 3px 5px;
      }
    }

    @media(max-width: 600px) {
      .container {
        padding: 12px;
      }

      .header-content h1 {
        font-size: 24px;
      }

      .calendar-day {
        min-height: 80px;
        padding: 6px;
        font-size: 10px;
      }

      .day-number {
        font-size: 12px;
      }

      .weekday-header {
        padding: 8px;
        font-size: 11px;
      }

      .modal-overlay {
        padding: 12px;
      }

      #applicantModal .modal-content {
        width: 100%;
        min-height: 0;
        max-height: 88vh;
        border-radius: 16px;
      }

      #applicantModal .modal-header {
        padding: 16px;
        align-items: flex-start;
        flex-wrap: wrap;
      }

      #applicantModal .modal-header-actions {
        width: 100%;
        justify-content: space-between;
      }

      #applicantModal .modal-header-actions .btn {
        flex: 1 1 auto;
      }

      .modal-body {
        padding: 16px;
      }

      .modal-title-row {
        align-items: flex-start;
        flex-direction: column;
        gap: 8px;
      }

      .applicant-item {
        align-items: flex-start;
        flex-direction: column;
      }

      .applicant-time {
        align-self: flex-start;
      }
    }
  </style>
</head>
<body>
  <div class="sidebar-overlay" id="sidebarOverlay"></div>
  
  <button class="hamburger" id="hamburger"><i class="fas fa-bars"></i></button>

  <%- include('./partials/sidebar', { page: 'weekly' }) %>

  <div class="main-content">
    <div class="page-logo">
      <img src="/images/logo.png" alt="PTC Logo" />
    </div>
    <div class="container">
      <div class="page-header">
        <a href="/admin/weekly-schedule" class="back-button">
          <i class="fas fa-arrow-left"></i> Back to Months
        </a>
      </div>

      <!-- Calendar Grid -->
      <div class="calendar-container">
        <div class="calendar-header">
          <button class="month-nav-btn" id="prevMonthBtn" onclick="goToPreviousMonth()" title="Previous Month">
            <i class="fas fa-chevron-left"></i>
          </button>
          <h2><%= monthName %> <%= year %></h2>
          <button class="month-nav-btn" id="nextMonthBtn" onclick="goToNextMonth()" title="Next Month">
            <i class="fas fa-chevron-right"></i>
          </button>
        </div>

        <div class="weekday-headers">
          <div class="weekday-header">Sun</div>
          <div class="weekday-header">Mon</div>
          <div class="weekday-header">Tue</div>
          <div class="weekday-header">Wed</div>
          <div class="weekday-header">Thu</div>
          <div class="weekday-header">Fri</div>
          <div class="weekday-header">Sat</div>
        </div>

        <div class="calendar-grid">
          <% 
            const holidays = holidayMap || {};
            const firstDay = new Date(year, month - 1, 1).getDay();
            const daysInMonth = new Date(year, month, 0).getDate();
            const daysInPrevMonth = new Date(year, month - 1, 0).getDate();

            // Previous month days
            for (let i = firstDay - 1; i >= 0; i--) {
              const day = daysInPrevMonth - i;
          %>
            <div class="calendar-day other-month">
              <span class="day-number"><%= day %></span>
            </div>
          <% } %>

          <!-- Current month days -->
          <% 
            for (let day = 1; day <= daysInMonth; day++) {
              const dateStr = `${year}-${String(month).padStart(2, '0')}-${String(day).padStart(2, '0')}`;
              const holidayKey = `${String(month).padStart(2, '0')}-${String(day).padStart(2, '0')}`;
              const holidayName = holidays[holidayKey] || '';
              const schedules = schedulesMap[dateStr] || [];
              const isToday = new Date().toISOString().split('T')[0] === dateStr;
          %>
            <div class="calendar-day <%= isToday ? 'today' : '' %> <%= holidayName ? 'holiday-day' : '' %>" <% if (holidayName) { %>title="<%= holidayName %>"<% } %>>
              <span class="day-number"><%= day %></span>
              <% if (holidayName) { %>
                <div class="holiday-label" aria-label="<%= holidayName %>" title="<%= holidayName %>">
                  <i class="fas fa-flag"></i>
                  <span><%= holidayName %></span>
                </div>
              <% } %>
              <% if (schedules.length > 0) { %>
                <button class="applicant-count" onclick="openApplicantModal('<%= dateStr %>')" title="Click to view applicants">
                  <i class="fas fa-users"></i> <%= schedules.length %>
                </button>
              <% } else { %>
                <div class="no-schedule">-</div>
              <% } %>
            </div>
          <% } %>

          <!-- Next month days -->
          <% 
            const totalCells = firstDay + daysInMonth;
            const remainingCells = totalCells % 7 === 0 ? 0 : 7 - (totalCells % 7);
            for (let day = 1; day <= remainingCells; day++) {
          %>
            <div class="calendar-day other-month">
              <span class="day-number"><%= day %></span>
            </div>
          <% } %>
        </div>
      </div>

      <!-- Detailed Schedule List -->
      <% if (schedulesList && schedulesList.length > 0) { %>
        <div class="schedule-details">
          <div class="schedule-details-header">
            <h3><i class="fas fa-list"></i> Detailed Schedule for <%= monthName %></h3>
          </div>
          <div class="schedule-list">
            <% schedulesList.forEach(schedule => { %>
              <div class="schedule-item">
                <div class="schedule-item-content">
                  <div class="schedule-item-date">
                    <i class="fas fa-calendar"></i> <%= new Date(schedule.examDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
                  </div>
                  <div class="schedule-item-applicant">
                    <i class="fas fa-user"></i> <%= schedule.fullName %>
                  </div>
                </div>
                <div class="schedule-item-time">
                  <i class="fas fa-clock"></i> <%= schedule.examTime %>
                </div>
              </div>
            <% }) %>
          </div>
        </div>
      <% } else { %>
        <div class="schedule-details">
          <div class="empty-message">
            <i class="fas fa-calendar-times"></i>
            <p>No schedules found for <%= monthName %></p>
          </div>
        </div>
      <% } %>
    </div>
  </div>

  <!-- Applicants Modal -->
  <div class="modal-overlay" id="applicantModal">
    <div class="modal-content">
      <div class="modal-header">
        <div class="modal-header-title">
          <span class="modal-kicker">Scheduled Applicants</span>
          <div class="modal-title-row">
            <h3 id="modalDateTitle">Applicants for Date</h3>
            <span class="applicant-count-pill" id="applicantCountPill">
              <i class="fas fa-users"></i>
              <span>0</span>
            </span>
          </div>
        </div>
        <div class="modal-header-actions">
          <button class="btn btn-primary export-btn" id="exportExcelBtn" onclick="exportScheduleExcel()" type="button">
            <i class="fas fa-file-export"></i>
            Export Excel
          </button>
          <button class="modal-close-btn" onclick="closeApplicantModal()" type="button" aria-label="Close applicants modal">
            <i class="fas fa-times"></i>
          </button>
        </div>
      </div>
      <div class="modal-body">
        <div class="modal-search">
          <i class="fas fa-search"></i>
          <input type="search" id="applicantSearchInput" placeholder="Search applicants by name or time..." class="search-input" aria-label="Search applicants by name or time" oninput="updateApplicantSearch()" />
        </div>
        <div id="exportStatusMessage" class="export-status hidden" role="status" aria-live="polite"></div>
        <div class="modal-filters">
          <button class="filter-btn active" id="filterAllBtn" onclick="setApplicantFilter('all')">All</button>
          <button class="filter-btn" id="filterAmBtn" onclick="setApplicantFilter('am')">AM</button>
          <button class="filter-btn" id="filterPmBtn" onclick="setApplicantFilter('pm')">PM</button>
        </div>
        <div id="modalBody">
          <!-- Applicants will be inserted here -->
        </div>
      </div>
    </div>
  </div>

  <script src="/js/script.js"></script>
  <script>
    // Store applicants data for modal
    const applicantsData = <%- JSON.stringify(schedulesMap) %>;
    let currentApplicantDate = null;
    let currentApplicantFilter = 'all';
    let currentApplicantSearch = '';

    function getTimePeriod(examTime) {
      if (typeof examTime !== 'string') return 'all';
      const normalized = examTime.toLowerCase();
      if (normalized.includes('a.m') || normalized.includes('am')) return 'am';
      if (normalized.includes('p.m') || normalized.includes('pm')) return 'pm';
      return 'all';
    }

    function updateFilterButtons(filter) {
      document.getElementById('filterAllBtn').classList.toggle('active', filter === 'all');
      document.getElementById('filterAmBtn').classList.toggle('active', filter === 'am');
      document.getElementById('filterPmBtn').classList.toggle('active', filter === 'pm');
    }

    function renderApplicantList() {
      if (!currentApplicantDate) {
        document.getElementById('modalBody').innerHTML = '';
        return;
      }

      const applicants = applicantsData[currentApplicantDate] || [];
      const filteredApplicants = applicants.filter(applicant => {
        if (currentApplicantFilter === 'am' && getTimePeriod(applicant.examTime) !== 'am') return false;
        if (currentApplicantFilter === 'pm' && getTimePeriod(applicant.examTime) !== 'pm') return false;

        const searchValue = currentApplicantSearch.trim().toLowerCase();
        if (!searchValue) return true;

        const nameMatches = applicant.fullName.toLowerCase().includes(searchValue);
        const timeMatches = applicant.examTime.toLowerCase().includes(searchValue);
        return nameMatches || timeMatches;
      });

      const filteredCount = filteredApplicants.length;
      const dateObj = new Date(currentApplicantDate);
      const formattedDate = dateObj.toLocaleDateString('en-US', {
        weekday: 'long',
        month: 'short',
        day: 'numeric',
        year: 'numeric'
      });

      const titleText = 'Applicants';
      document.getElementById('modalDateTitle').textContent = `${titleText} - ${formattedDate}`;
      const countPill = document.getElementById('applicantCountPill');
      if (countPill) {
        const countText = `${filteredCount} ${filteredCount === 1 ? 'applicant' : 'applicants'}`;
        countPill.querySelector('span').textContent = countText;
      }

      let modalBodyHTML = '';
      if (filteredApplicants.length > 0) {
        filteredApplicants.forEach(applicant => {
          modalBodyHTML += `
            <div class="applicant-item">
              <div class="applicant-main">
                <span class="applicant-avatar"><i class="fas fa-user"></i></span>
                <span class="applicant-name">${applicant.fullName}</span>
              </div>
              <span class="applicant-time"><i class="fas fa-clock"></i> ${applicant.examTime}</span>
            </div>
          `;
        });
      } else {
        modalBodyHTML = `
          <div class="empty-applicants">
            <i class="fas fa-inbox"></i>
            <p>No ${currentApplicantFilter === 'all' ? '' : currentApplicantFilter.toUpperCase() + ' '}applicants scheduled for this date</p>
          </div>
        `;
      }

      document.getElementById('modalBody').innerHTML = modalBodyHTML;
    }

    function setApplicantFilter(filter) {
      currentApplicantFilter = filter;
      updateFilterButtons(filter);
      renderApplicantList();
    }

    function updateApplicantSearch() {
      const searchInput = document.getElementById('applicantSearchInput');
      currentApplicantSearch = searchInput ? searchInput.value : '';
      renderApplicantList();
    }

    let isExportInProgress = false;

    function openApplicantModal(dateStr) {
      currentApplicantDate = dateStr;
      currentApplicantFilter = 'all';
      currentApplicantSearch = '';
      const searchInput = document.getElementById('applicantSearchInput');
      if (searchInput) {
        searchInput.value = '';
      }
      updateFilterButtons('all');
      renderApplicantList();
      currentApplicantDate = dateStr;
      currentApplicantFilter = 'all';
      updateFilterButtons('all');
      renderApplicantList();

      hideExportStatus();
      const exportButton = document.getElementById('exportExcelBtn');
      if (exportButton) {
        exportButton.disabled = false;
        exportButton.textContent = '';
        exportButton.innerHTML = '<i class="fas fa-file-export"></i> Export Excel';
      }

      document.getElementById('applicantModal').classList.add('active');
      document.body.style.overflow = 'hidden';
    }

    function closeApplicantModal() {
      document.getElementById('applicantModal').classList.remove('active');
      document.body.style.overflow = 'auto';
    }

    // Close modal when clicking on overlay
    document.getElementById('applicantModal').addEventListener('click', function(e) {
      if (e.target === this) {
        closeApplicantModal();
      }
    });

    async function exportScheduleExcel() {
      if (!currentApplicantDate) {
        showExportStatus('Please open a date before exporting.', 'error');
        return;
      }
      if (isExportInProgress) return;

      const exportButton = document.getElementById('exportExcelBtn');
      const searchTerm = currentApplicantSearch || '';
      const filterValue = currentApplicantFilter || 'all';
      const query = new URLSearchParams({
        examDate: currentApplicantDate,
        filter: filterValue,
        search: searchTerm
      }).toString();

      try {
        isExportInProgress = true;
        if (exportButton) {
          exportButton.disabled = true;
          exportButton.textContent = 'Exporting...';
        }
        hideExportStatus();

        const response = await fetch(`/admin/export-schedule?${query}`);
        const contentType = response.headers.get('content-type') || '';
        if (!response.ok) {
          const errorData = contentType.includes('application/json') ? await response.json() : null;
          throw new Error(errorData?.error || 'Failed to generate Excel file.');
        }

        const blob = await response.blob();
        if (!blob || blob.size === 0) {
          throw new Error('Received an empty file from the server.');
        }

        const disposition = response.headers.get('content-disposition') || '';
        let filename = `exam-schedule-${currentApplicantDate}.xlsx`;
        const filenameMatch = disposition.match(/filename="?([^";]+)"?/i);
        if (filenameMatch) {
          filename = filenameMatch[1];
        }

        const url = window.URL.createObjectURL(blob);
        const link = document.createElement('a');
        link.href = url;
        link.download = filename;
        document.body.appendChild(link);
        link.click();
        link.remove();
        window.URL.revokeObjectURL(url);

        showExportStatus('Excel export complete. The file has started downloading.', 'success');
      } catch (error) {
        console.error('Export error:', error);
        showExportStatus(error.message || 'Unable to export the selected schedule.', 'error');
      } finally {
        isExportInProgress = false;
        if (exportButton) {
          exportButton.disabled = false;
          exportButton.innerHTML = '<i class="fas fa-file-export"></i> Export Excel';
        }
      }
    }

    function showExportStatus(message, type) {
      const statusElement = document.getElementById('exportStatusMessage');
      if (!statusElement) return;
      statusElement.textContent = message;
      statusElement.className = `export-status ${type}`;
    }

    function hideExportStatus() {
      const statusElement = document.getElementById('exportStatusMessage');
      if (!statusElement) return;
      statusElement.textContent = '';
      statusElement.className = 'export-status hidden';
    }

    // Close modal on Escape key
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        closeApplicantModal();
      }
    });

    // Navigation between months (restricted to March-August)
    function goToNextMonth() {
      const currentMonth = <%= month %>;
      const currentYear = <%= year %>;
      let nextMonth = currentMonth + 1;
      let nextYear = currentYear;
      
      // Restrict to August (month 8)
      if (nextMonth > 8) {
        return; // Don't navigate past August
      }
      
      if (nextMonth > 12) {
        nextMonth = 1;
        nextYear++;
      }
      
      window.location.href = `/admin/month/${nextMonth}`;
    }

    function goToPreviousMonth() {
      const currentMonth = <%= month %>;
      const currentYear = <%= year %>;
      let prevMonth = currentMonth - 1;
      let prevYear = currentYear;
      
      // Restrict to March (month 3)
      if (prevMonth < 3) {
        return; // Don't navigate above March
      }
      
      if (prevMonth < 1) {
        prevMonth = 12;
        prevYear--;
      }
      
      window.location.href = `/admin/month/${prevMonth}`;
    }

    // Disable navigation buttons at boundaries
    window.addEventListener('DOMContentLoaded', function() {
      const currentMonth = <%= month %>;
      const prevBtn = document.getElementById('prevMonthBtn');
      const nextBtn = document.getElementById('nextMonthBtn');
      
      // Disable previous button if at March
      if (currentMonth <= 3) {
        prevBtn.disabled = true;
      }
      
      // Disable next button if at August
      if (currentMonth >= 8) {
        nextBtn.disabled = true;
      }
    });
  </script>
</body>
</html>
