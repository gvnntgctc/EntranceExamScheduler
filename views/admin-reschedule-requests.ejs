<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Reschedule Requests</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="admin-page-bg">
  <%- include('partials/sidebar', { page: 'rescheduleRequests' }) %>
  <div class="sidebar-overlay" id="sidebarOverlay"></div>
  <button class="hamburger" id="hamburger" aria-label="Open menu"><i class="fas fa-bars"></i></button>
  <div class="main-content">
    <div class="page-logo"><img src="/images/logo.png" alt="PTC Logo" /></div>
    <div class="container">
      <h1><i class="fas fa-calendar-plus"></i> Reschedule Requests</h1>
      <% if (error) { %><div class="message error"><%= error %></div><% } %>
      <% if (success) { %><div class="message success"><%= success %></div><% } %>
      <div class="section-card">
        <% if (!requests.length) { %>
          <div class="no-data"><p>No reschedule requests need review.</p></div>
        <% } else { %>
          <div class="table-responsive">
            <table class="schedule-table">
              <thead><tr><th>Applicant</th><th>Reason</th><th>Status</th><th>Submitted</th><th>Review</th></tr></thead>
              <tbody>
                <% requests.forEach(request => { %>
                  <tr>
                    <td><%= request.studentId ? request.studentId.fullName || request.studentId.email : 'Unknown applicant' %></td>
                    <td><%= request.reason %></td>
                    <td><%= request.status %></td>
                    <td><%= new Date(request.createdAt).toLocaleString('en-US') %></td>
                    <td>
                      <% if (request.status === 'pending') { %>
                        <form action="/admin/reschedule-requests/<%= request._id %>/status" method="POST" class="form-buttons">
                          <input type="text" name="adminNote" placeholder="Optional note" aria-label="Admin note">
                          <button class="btn btn-primary" name="status" value="approved">Approve</button>
                          <button class="btn btn-secondary" name="status" value="rejected">Reject</button>
                        </form>
                      <% } else { %>
                        <%= request.adminNote || 'Reviewed' %>
                      <% } %>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>
  </div>
  <script src="/js/script.js"></script>
</body>
</html>
