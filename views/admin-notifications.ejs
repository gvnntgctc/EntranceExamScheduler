<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin - Activity Log</title>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet" />
  <link href="/css/style.css" rel="stylesheet" />
  <style>
    .section-card {
      background: rgba(255, 255, 255, 0.76);
      border: 1px solid rgba(227, 232, 238, 0.70);
      border-radius: 12px;
      padding: 22px;
      box-shadow: 0 10px 26px rgba(21, 34, 56, 0.08);
      margin-bottom: 18px;
    }
    .search-bar {
      display: flex;
      gap: 12px;
      align-items: center;
      margin-bottom: 18px;
      flex-wrap: wrap;
    }
    .notifications-table {
      width: 100%;
      min-width: 860px;
      border-collapse: collapse;
      background: rgba(255, 255, 255, 0.80);
      table-layout: fixed;
      font-size: 14px;
    }
    .notifications-table th,
    .notifications-table td {
      padding: 14px 16px;
      border-bottom: 1px solid #edf2f7;
      vertical-align: top;
      color: #2a3f57;
      white-space: normal;
      word-break: break-word;
      overflow-wrap: anywhere;
      min-width: 0;
    }
    .notifications-table th:nth-child(1),
    .notifications-table td:nth-child(1) {
      width: 5%;
      min-width: 40px;
      white-space: nowrap;
    }
    .notifications-table th:nth-child(2),
    .notifications-table td:nth-child(2) {
      width: 18%;
      min-width: 150px;
    }
    .notifications-table th:nth-child(3),
    .notifications-table td:nth-child(3) {
      width: 18%;
      min-width: 150px;
    }
    .notifications-table th:nth-child(4),
    .notifications-table td:nth-child(4) {
      width: 28%;
      min-width: 220px;
    }
    .notifications-table th:nth-child(5),
    .notifications-table td:nth-child(5) {
      width: 10%;
      min-width: 100px;
      white-space: nowrap;
    }
    .notifications-table th:nth-child(6),
    .notifications-table td:nth-child(6) {
      width: 12%;
      min-width: 110px;
      white-space: nowrap;
    }
    .notifications-table th:nth-child(7),
    .notifications-table td:nth-child(7) {
      width: 9%;
      min-width: 100px;
      white-space: nowrap;
    }
    .sent-at {
      white-space: normal;
      text-align: center;
      vertical-align: middle;
    }
    .manage-actions {
      display: flex;
      gap: 8px;
      align-items: center;
      justify-content: flex-start;
      white-space: nowrap;
    }
    .admin-notifications-page .table-responsive {
      overflow-x: auto;
    }
    .admin-notifications-page .notifications-table {
      table-layout: fixed;
      width: 100%;
      min-width: 860px;
    }
    .admin-notifications-page .notifications-table th,
    .admin-notifications-page .notifications-table td {
      min-width: 0;
      word-break: break-word;
      overflow-wrap: anywhere;
      white-space: normal;
    }
    .admin-notifications-page .notifications-table th:nth-child(2),
    .admin-notifications-page .notifications-table td:nth-child(2) {
      width: 18%;
      min-width: 150px;
    }
    .admin-notifications-page .notifications-table th:nth-child(3),
    .admin-notifications-page .notifications-table td:nth-child(3) {
      width: 18%;
      min-width: 150px;
    }
    .admin-notifications-page .notifications-table th:nth-child(4),
    .admin-notifications-page .notifications-table td:nth-child(4) {
      width: 28%;
      min-width: 220px;
    }
    .admin-notifications-page .notifications-table th:nth-child(5),
    .admin-notifications-page .notifications-table td:nth-child(5) {
      width: 10%;
      min-width: 100px;
      white-space: nowrap;
    }
    .admin-notifications-page .notifications-table th:nth-child(6),
    .admin-notifications-page .notifications-table td:nth-child(6) {
      width: 12%;
      min-width: 110px;
      white-space: nowrap;
    }
    .admin-notifications-page .notifications-table th:nth-child(7),
    .admin-notifications-page .notifications-table td:nth-child(7) {
      width: 9%;
      min-width: 100px;
      white-space: nowrap;
    }
    .view-details-btn {
      padding: 9px;
      min-width: 38px;
      justify-content: center;
    }
    .notifications-table th {
      background: #f3f6fa;
      font-weight: 700;
      color: #4a5568;
      text-transform: uppercase;
      letter-spacing: 0.6px;
      font-size: 13px;
    }
    .details-cell {
      max-width: 320px;
      white-space: normal;
      color: #475569;
      font-size: 13px;
      line-height: 1.5;
    }
    .sent-at {
      white-space: nowrap;
      text-align: center;
      vertical-align: middle;
    }
    .details-cell .subject-line {
      display: block;
      font-weight: 700;
      color: #1f2937;
      margin-bottom: 6px;
    }
    .manage-actions {
      display: flex;
      gap: 8px;
      align-items: center;
      justify-content: flex-start;
    }
    .status-pill {
      border-radius: 999px;
      padding: 6px 12px;
      font-size: 12px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.4px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 82px;
    }
    .status-sent { background: #d4edda; color: #155724; }
    .status-failed { background: #f8d7da; color: #721c24; }
    .message { margin: 12px 0; }
    .message.error { background: #fff3f1; color: #a33d2b; border: 1px solid #f7c2b8; padding: 10px; border-radius: 8px; }
    .message.success { background: #ecfdf5; color: #1f7a4b; border: 1px solid #a7f3d0; padding: 10px; border-radius: 8px; }
    
    .view-details-btn {
      background: #42b72a;
      border: none;
      color: white;
      padding: 9px 14px;
      border-radius: 8px;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
      font-size: 13px;
      font-weight: 700;
      cursor: pointer;
      box-shadow: 0 4px 14px rgba(17, 153, 142, 0.18);
    }
    .view-details-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 18px rgba(17, 153, 142, 0.25);
      background: linear-gradient(135deg, #0e7a70 0%, #2dd66f 100%);
    }
    .pagination {
      margin-top: 18px;
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      justify-content: flex-start;
      align-items: center;
    }
    .page-link {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 42px;
      padding: 8px 12px;
      border-radius: 8px;
      border: 1px solid #d2d6dc;
      background: rgba(255, 255, 255, 0.86);
      color: #1f2937;
      text-decoration: none;
      font-size: 13px;
      font-weight: 600;
      transition: background 0.2s ease, border-color 0.2s ease;
    }
    .page-link:hover {
      background: #f3f6fa;
      border-color: #cbd5e1;
    }
    .page-link.active {
      background: #0f766e;
      color: #fff;
      border-color: #0f766e;
    }

    @media (max-width: 900px) {
      .section-card {
        padding: 16px 14px;
      }

      .search-bar {
        flex-direction: column;
        gap: 8px;
        align-items: stretch;
        margin-bottom: 12px;
        padding: 8px 10px;
      }

      .search-input-wrapper {
        width: 100%;
        min-width: 0;
      }

      .search-bar input,
      .search-bar select {
        padding: 10px 12px;
        font-size: 13px;
      }

      .notifications-table {
        display: block;
        width: 100%;
        max-width: 100%;
        min-width: 0;
        table-layout: auto;
      }

      .notifications-table thead {
        display: none;
      }

      .notifications-table tbody {
        display: block;
      }

      .notifications-table tr {
        display: grid;
        grid-template-columns: auto 1fr auto;
        grid-template-areas:
          "index recipient manage"
          "action action action"
          "details details details"
          "status sent sent";
        gap: 6px 10px;
        margin-bottom: 10px;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        padding: 10px 12px;
        background: #ffffff;
        box-shadow: 0 6px 14px rgba(15, 23, 42, 0.05);
      }

      .notifications-table td {
        display: block;
        width: 100%;
        padding: 3px 0;
        border: none;
        box-sizing: border-box;
        line-height: 1.35;
        color: #334155;
      }

      .notifications-table td:first-child {
        grid-area: index;
        align-self: center;
        padding-top: 3px;
      }

      .notifications-table td:nth-child(2) {
        grid-area: recipient;
        padding-top: 3px;
      }

      .notifications-table td:nth-child(3) {
        grid-area: action;
        padding-top: 3px;
      }

      .notifications-table td:nth-child(4) {
        grid-area: details;
        padding-top: 3px;
      }

      .notifications-table td:nth-child(5) {
        grid-area: status;
        padding-top: 4px;
      }

      .notifications-table td:nth-child(6) {
        grid-area: sent;
        color: #64748b;
        font-size: 13px;
        padding-top: 4px;
      }

      .notifications-table td:last-child {
        grid-area: manage;
        justify-self: end;
        align-self: center;
        padding-top: 4px;
      }

      .notifications-table td:before {
        display: none;
      }

      .details-cell {
        padding-top: 2px;
        color: #475569;
        font-size: 13px;
        line-height: 1.45;
      }

      .details-cell .subject-line {
        margin-bottom: 4px;
        font-size: 14px;
      }

      .status-pill {
        padding: 4px 8px;
        font-size: 12px;
        min-width: auto;
      }

      .view-details-btn {
        padding: 7px 10px;
        font-size: 12px;
        border-radius: 10px;
        min-width: auto;
        width: auto;
        box-shadow: 0 8px 16px rgba(17, 153, 142, 0.10);
      }

      .sent-at {
        text-align: left;
      }
    }

    @media (max-width: 600px) {
      .notifications-table tr {
        grid-template-columns: auto 1fr;
        grid-template-areas:
          "index manage"
          "recipient recipient"
          "action action"
          "details details"
          "status sent";
        padding: 9px 10px;
        gap: 5px 8px;
      }

      .notifications-table td {
        padding: 3px 0;
      }

      .view-details-btn {
        width: auto;
        padding: 7px 10px;
        font-size: 12px;
      }

      .search-bar {
        gap: 8px;
      }
    }
  </style>
</head>
<body class="admin-notifications-page admin-page-bg">
  <%- include('partials/sidebar'); %>
  <div class="sidebar-overlay" id="sidebarOverlay"></div>
  <button class="hamburger" id="hamburger"><i class="fas fa-bars"></i></button>
  <div class="main-content">
    <div class="page-logo">
      <img src="/images/logo.png" alt="PTC Logo" />
    </div>
    <div class="container">
      <h1><i class="fas fa-bell"></i> Admin Activity Log</h1>
      <% if (error && error.length > 0) { %>
        <div class="message error"><i class="fas fa-exclamation-circle"></i> <%= error %></div>
      <% } %>
      <% if (success && success.length > 0) { %>
        <div class="message success"><i class="fas fa-check-circle"></i> <%= success %></div>
      <% } %>
      <div class="section-card">
        <div class="search-bar">
          <div class="search-input-wrapper">
            <i class="fas fa-search search-icon"></i>
            <input id="notificationSearch" class="search-input" type="search" placeholder="Search recipient or action..." aria-label="Search notifications" value="<%= search %>" autocomplete="off" />
          </div>
        </div>

        <div class="table-responsive">
          <table class="notifications-table">
            <thead>
              <tr>
                <th>#</th>
                <th>Recipient</th>
                <th>Action</th>
                <th>Details</th>
                <th>Status</th>
                <th>Sent At</th>
                <th>Manage</th>
              </tr>
            </thead>
            <tbody>
              <% if (notifications.length === 0) { %>
                <tr><td colspan="7" style="text-align:center; color:#66788a;">No activity logged yet.</td></tr>
              <% } %>
              <% notifications.forEach((notification, idx) => { %>
                <tr>
                  <td><%= idx + 1 %></td>
                  <td><strong><%= notification.recipientEmail %></strong></td>
                  <td><%= notification.actionDescription %></td>
                  <td class="details-cell">
                    <span class="subject-line"><%= notification.subject %></span>
                  </td>
                  <td><span class="status-pill status-<%= notification.status %>"><%= notification.status %></span></td>
                  <td class="sent-at" data-timestamp="<%= notification.createdAt.toISOString() %>"></td>
                  <td class="manage-actions">
                    <a href="/admin/notifications/<%= notification._id %>" class="view-details-btn" aria-label="View notification details"><i class="fas fa-eye"></i></a>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
          <% if (totalPages > 1) { %>
            <div class="pagination">
              <% if (currentPage > 1) { %>
                <a href="/admin/notifications?search=<%= encodeURIComponent(search) %>&status=<%= status %>&page=<%= currentPage - 1 %>" class="page-link">Previous</a>
              <% } %>
              <% for (let p = 1; p <= totalPages; p++) { %>
                <a href="/admin/notifications?search=<%= encodeURIComponent(search) %>&status=<%= status %>&page=<%= p %>" class="page-link <%= currentPage === p ? 'active' : '' %>"><%= p %></a>
              <% } %>
              <% if (currentPage < totalPages) { %>
                <a href="/admin/notifications?search=<%= encodeURIComponent(search) %>&status=<%= status %>&page=<%= currentPage + 1 %>" class="page-link">Next</a>
              <% } %>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>

  <script src="/js/script.js"></script>
  <script>
    const searchInput = document.getElementById('notificationSearch');
    const tableBody = document.querySelector('.notifications-table tbody');

    function formatLocalTimestamp(isoString) {
      if (!isoString) return '';
      const date = new Date(isoString);
      if (Number.isNaN(date.getTime())) return '';

      const month = (date.getMonth() + 1).toString().padStart(2, '0');
      const day = date.getDate().toString().padStart(2, '0');
      const year = date.getFullYear();
      const hours = date.getHours();
      const minutes = date.getMinutes().toString().padStart(2, '0');
      const ampm = hours >= 12 ? 'PM' : 'AM';
      const displayHours = hours % 12 || 12;
      return `${month}/${day}/${year} ${displayHours}:${minutes} ${ampm}`;
    }

    // Format all timestamps on page load
    document.querySelectorAll('.sent-at').forEach(cell => {
      const timestamp = cell.getAttribute('data-timestamp');
      cell.textContent = formatLocalTimestamp(timestamp);
    });

    function applyLiveFilters() {
      const searchTerm = searchInput.value.trim().toLowerCase();
      const rows = tableBody.querySelectorAll('tr');
      let visibleCount = 0;

      rows.forEach(row => {
        // Skip the "no data" row
        if (row.cells.length < 7) {
          row.style.display = '';
          return;
        }

        const recipient = row.cells[1]?.textContent.toLowerCase() || '';
        const action = row.cells[2]?.textContent.toLowerCase() || '';
        const status = row.cells[4]?.textContent.trim().toLowerCase() || '';
        
        const matchesSearch = searchTerm === '' || 
          recipient.includes(searchTerm) || 
          action.includes(searchTerm);
        
        if (matchesSearch) {
          row.style.display = '';
          visibleCount++;
        } else {
          row.style.display = 'none';
        }
      });

      // Update row numbers
      let rowIndex = 1;
      rows.forEach(row => {
        if (row.style.display !== 'none' && row.cells.length >= 7) {
          row.cells[0].textContent = rowIndex++;
        }
      });
    }

    searchInput.addEventListener('input', applyLiveFilters);
  </script>
</body>
</html>
