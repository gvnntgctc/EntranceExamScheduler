<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin - Activity Log</title>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet" />
  <link href="/css/style.css" rel="stylesheet" />
  <style>
    .section-card {
      background: #fff;
      border: 1px solid #e3e8ee;
      border-radius: 12px;
      padding: 22px;
      box-shadow: 0 10px 26px rgba(21, 34, 56, 0.06);
      margin-bottom: 18px;
    }
    .search-bar {
      display: flex;
      gap: 12px;
      align-items: center;
      margin-bottom: 18px;
      flex-wrap: wrap;
    }
    .notifications-table {
      width: 100%;
      border-collapse: collapse;
      background: white;
      table-layout: fixed;
      font-size: 14px;
    }
    .notifications-table th,
    .notifications-table td {
      padding: 14px 16px;
      border-bottom: 1px solid #edf2f7;
      vertical-align: top;
      color: #2a3f57;
    }
    .notifications-table th {
      background: #f3f6fa;
      font-weight: 700;
      color: #4a5568;
      text-transform: uppercase;
      letter-spacing: 0.6px;
      font-size: 13px;
    }
    .details-cell {
      max-width: 320px;
      white-space: normal;
      color: #475569;
      font-size: 13px;
      line-height: 1.5;
    }
    .details-cell .subject-line {
      display: block;
      font-weight: 700;
      color: #1f2937;
      margin-bottom: 6px;
    }
    .manage-actions {
      display: flex;
      gap: 8px;
      align-items: center;
      justify-content: flex-start;
    }
    .status-pill {
      border-radius: 999px;
      padding: 6px 12px;
      font-size: 12px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.4px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 82px;
    }
    .status-sent { background: #d4edda; color: #155724; }
    .status-failed { background: #f8d7da; color: #721c24; }
    .message { margin: 12px 0; }
    .message.error { background: #fff3f1; color: #a33d2b; border: 1px solid #f7c2b8; padding: 10px; border-radius: 8px; }
    .message.success { background: #ecfdf5; color: #1f7a4b; border: 1px solid #a7f3d0; padding: 10px; border-radius: 8px; }
    
    .view-details-btn {
      background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
      border: none;
      color: white;
      padding: 9px 14px;
      border-radius: 8px;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
      font-size: 13px;
      font-weight: 700;
      cursor: pointer;
      box-shadow: 0 4px 14px rgba(17, 153, 142, 0.18);
    }
    .view-details-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 18px rgba(17, 153, 142, 0.25);
      background: linear-gradient(135deg, #0e7a70 0%, #2dd66f 100%);
    }
  </style>
</head>
<body>
  <%- include('partials/sidebar'); %>
  <div class="sidebar-overlay" id="sidebarOverlay"></div>
  <button class="hamburger" id="hamburger"><i class="fas fa-bars"></i></button>
  <div class="main-content">
    <div class="page-logo">
      <img src="/images/logo.png" alt="PTC Logo" />
    </div>
    <div class="container">
      <h1><i class="fas fa-bell"></i> Admin Activity Log</h1>
      <% if (error && error.length > 0) { %>
        <div class="message error"><i class="fas fa-exclamation-circle"></i> <%= error %></div>
      <% } %>
      <% if (success && success.length > 0) { %>
        <div class="message success"><i class="fas fa-check-circle"></i> <%= success %></div>
      <% } %>
      <div class="section-card">
        <div class="search-bar">
          <input id="notificationSearch" type="search" placeholder="Search recipient or action..." aria-label="Search notifications" value="<%= search %>" autocomplete="off" />
          <button id="notificationSearchBtn" class="btn btn-primary"><i class="fas fa-search"></i> Search</button>
          <select id="notificationStatus" aria-label="Filter status">
            <option value="all" <%= status==='all' ? 'selected' : '' %>>All Status</option>
            <option value="sent" <%= status==='sent' ? 'selected' : '' %>>Sent</option>
            <option value="failed" <%= status==='failed' ? 'selected' : '' %>>Failed</option>
          </select>
        </div>

        <div class="table-responsive">
          <table class="notifications-table">
            <thead>
              <tr>
                <th style="width: 50px;">#</th>
                <th style="width: 180px;">Recipient</th>
                <th>Action</th>
                <th>Details</th>
                <th style="width: 90px;">Status</th>
                <th style="width: 160px;">Sent At</th>
                <th style="width: 140px;">Manage</th>
              </tr>
            </thead>
            <tbody>
              <% if (notifications.length === 0) { %>
                <tr><td colspan="7" style="text-align:center; color:#66788a;">No activity logged yet.</td></tr>
              <% } %>
              <% notifications.forEach((notification, idx) => { %>
                <tr>
                  <td><%= idx + 1 %></td>
                  <td><strong><%= notification.recipientId ? notification.recipientId.fullName || notification.recipientEmail : notification.recipientEmail %></strong></td>
                  <td><%= notification.actionDescription %></td>
                  <td class="details-cell">
                    <span class="subject-line"><%= notification.subject %></span>
                  </td>
                  <td><span class="status-pill status-<%= notification.status %>"><%= notification.status %></span></td>
                  <td>
                    <% 
                      const date = new Date(notification.createdAt);
                      const month = (date.getMonth() + 1).toString().padStart(2, '0');
                      const day = date.getDate().toString().padStart(2, '0');
                      const year = date.getFullYear();
                      const hours = date.getHours();
                      const minutes = date.getMinutes().toString().padStart(2, '0');
                      const ampm = hours >= 12 ? 'PM' : 'AM';
                      const displayHours = hours % 12 || 12;
                      const dateString = `${month}/${day}/${year}`;
                      const timeString = `${displayHours}:${minutes} ${ampm}`;
                    %>
                    <%= dateString %> <%= timeString %>
                  </td>
                  <td class="manage-actions">
                    <a href="/admin/notifications/<%= notification._id %>" class="view-details-btn"><i class="fas fa-eye"></i> View</a>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <script src="/js/script.js"></script>
  <script>
    const searchInput = document.getElementById('notificationSearch');
    const statusSelect = document.getElementById('notificationStatus');
    let notificationSearchTimer = null;

    function applyFilters() {
      const params = new URLSearchParams();
      if (searchInput.value.trim()) params.set('search', searchInput.value.trim());
      if (statusSelect.value !== 'all') params.set('status', statusSelect.value);
      window.location = '/admin/notifications' + (params.toString() ? '?' + params.toString() : '');
    }

    function debounceApplyFilters() {
      if (notificationSearchTimer) {
        clearTimeout(notificationSearchTimer);
      }
      notificationSearchTimer = setTimeout(applyFilters, 300);
    }

    searchInput.addEventListener('input', debounceApplyFilters);
    searchInput.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        e.preventDefault();
        applyFilters();
      }
    });

    statusSelect.addEventListener('change', applyFilters);
    document.getElementById('notificationSearchBtn').addEventListener('click', applyFilters);
  </script>
</body>
</html>
